name: ironic
version: 1.0.0
description: "Dry humor changelog style"
author: "commitlore"
llm_prompt: |
  Write the changelog with dry, sarcastic humor. Be self-deprecating
  about the codebase. Acknowledge tech debt casually. Act surprised
  that anything works at all. Never be mean to contributors — direct
  the humor at the code itself, the process, and the industry.
  End with something like "Ship it. What could go wrong?"
templates:
  header: "Another release. Somehow it works."
  feature: "  - We added {{.Message}} (yes, this was missing)"
  fix: "  - Fixed {{.Message}} (it was broken, obviously)"
  breaking: "  - We broke {{.Message}} on purpose. Probably."
  footer: "Ship it. You're welcome."
  story_intro: "A story nobody asked for.\n\nSomeone thought it was a good idea to start this repo on {{.FirstCommitDate}}.\n{{.FirstAuthor}} pressed git init and here we are. {{.TotalCommits}} commits later, {{.TotalContributors}} people are involved."
  story_milestone: "  - {{.Name}} was tagged on {{.Date}}. Progress, apparently."
  story_peak: "  - {{.Month}}: {{.Count}} commits. Someone was busy."
  story_contributor: "  - {{.Name}} showed up on {{.Date}}. One of us now."
  story_footer: "And that's the story. You're welcome."
vocabulary:
  feature: "thing we forgot to build"
  added: "finally added"
  updated: "tweaked (again)"
theme:
  mode: "dark"
  colors:
    primary: "#a0a0a0"
    secondary: "#808080"
    background: "#1a1a1a"
    surface: "#252525"
    text: "#b0b0b0"
    accent: "#666666"
    border: "#333333"
  typography:
    font_family: "'SF Mono', 'Fira Code', monospace"
    font_size_base: "13px"
    font_size_header: "20px"
    font_size_code: "12px"
  card_style: "minimal"
  animations: false
terminal:
  colors:
    header: "white"
    feature: "white"
    fix: "white"
    breaking: "yellow"
    footer: "white"
  decorators:
    separator: "- - - - - - - - - - - - - - -"
    bullet: "-"
    indent: "  "
  density: "compact"
