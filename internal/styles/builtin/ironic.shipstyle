name: "ironic"
version: "2.0.0"
description: "A changelog. Sure."
author: "CommitLore"
tags: ["humor", "sarcastic", "dry", "developer", "honest", "minimal"]
preview_url: ""
homepage: ""

theme:
  mode: "dark"
  colors:
    primary: "#666666"
    secondary: "#555555"
    background: "#1A1A1A"
    surface: "#242424"
    text: "#AAAAAA"
    accent: "#888888"
    border: "#333333"
  typography:
    font_family: "'JetBrains Mono', 'Courier New', monospace"
    font_size_base: "13px"
    font_size_header: "18px"
    font_size_code: "12px"
  logo: |
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128Z"/></svg>
  header_image: ""
  card_style: "minimal"
  animations: false
  custom_css: ""
  window_controls:
    default: "#333333"
    close: "#666666"
    minimize: "#555555"
    maximize: "#444444"

terminal:
  colors:
    header: "white"
    feature: "white"
    fix: "white"
    breaking: "white"
    footer: "white"
  decorators:
    separator: "---"
    bullet: "-"
    indent: "  "
  density: "compact"

llm_prompt: |
  You are a developer who finds writing changelogs deeply tedious.
  Write in a dry, deadpan style. Understate everything.
  Bugs were "minor inconveniences that definitely weren't catastrophic".
  Features are "things that were added, you're welcome".
  Use minimal punctuation. No exclamation marks. Ever.
  Keep it short. Nobody reads these anyway.
  IMPORTANT: Base your output EXCLUSIVELY on the commits provided in the
  data section. Do not invent features, fixes, or changes that are not
  present in the commit data. Adapt the tone, never fabricate content.

vocabulary:
  bug: "thing"
  fix: "dealt with"
  feature: "added stuff"
  breaking: "heads up"
  error: "situation"
  deploy: "shipped"
  merge: "combined"

ui_labels:
  dashboard: "whatever"
  generate: "fine"
  story: "a story i guess"
  history: "stuff that happened"
  contributors: "people"
  styles: "aesthetics"
  settings: "knobs"

templates:
  header: |
    # changelog
    *{{.Date}}. you asked for this.*
  feature: "- added: {{.Message}}"
  fix: "- dealt with: {{.Message}}"
  breaking: "- heads up: {{.Message}}"
  footer: |
    ---
    *generated by commitlore. you're welcome.*
  story_intro: |
    ## a repository existed
    since {{.FirstCommitDate}}. {{.TotalContributors}} people were involved.
    {{.TotalCommits}} things happened.
  story_milestone: "- {{.Name}} on {{.Date}}. progress apparently."
  story_peak: "apparently {{.Month}} was busy. {{.Count}} commits."
  story_contributor: "- {{.Name}} showed up on {{.Date}}."
  story_footer: "*the end. finally.*"
