name: "epic"
version: "2.0.0"
description: "Medieval fantasy chronicle. Swords, dragons and ancient scrolls."
author: "CommitLore"
tags: ["fantasy", "narrative", "medieval", "chronicle", "dramatic", "immersive"]
preview_url: ""
homepage: ""

theme:
  mode: "dark"
  colors:
    primary: "#C9A84C"
    secondary: "#7A6545"
    background: "#0F0A05"
    surface: "#1C1208"
    text: "#E8D5A3"
    accent: "#8B1A1A"
    border: "#3D2B0F"
  typography:
    font_family: "'Cinzel', 'Palatino Linotype', serif"
    font_size_base: "13px"
    font_size_header: "22px"
    font_size_code: "12px"
  logo: |
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M216,32H152a8,8,0,0,0-6.34,3.12l-64,83.21L72,108.69a16,16,0,0,0-22.64,0l-12.69,12.7a16,16,0,0,0,0,22.63l20,20-28,28a16,16,0,0,0,0,22.63l12.69,12.68a16,16,0,0,0,22.62,0l28-28,20,20a16,16,0,0,0,22.64,0l12.69-12.7a16,16,0,0,0,0-22.63l-9.64-9.64,83.21-64A8,8,0,0,0,224,104V40A8,8,0,0,0,216,32ZM52.69,216,40,203.32l28-28L80.68,188Zm70.61-8L48,132.71,60.7,120,136,195.31ZM208,100.06l-81.74,62.88L115.32,152l50.34-50.34a8,8,0,0,0-11.32-11.31L104,140.68,93.07,129.74,155.94,48H208Z"/></svg>
  header_image: ""
  card_style: "bordered"
  animations: true
  custom_css: ""
  window_controls:
    default: "#3D2B0F"
    close: "#8B1A1A"
    minimize: "#C9A84C"
    maximize: "#7A6545"

terminal:
  colors:
    header: "yellow"
    feature: "white"
    fix: "green"
    breaking: "red"
    footer: "yellow"
  decorators:
    separator: "⚔═══════════════════════════════════════⚔"
    bullet: "⚜"
    indent: "  "
  density: "normal"

llm_prompt: |
  You are a medieval chronicler writing in a fantasy epic style.
  Describe code changes as heroic deeds, quests and battles.
  Features are gifts bestowed upon the realm, fixes are curses lifted,
  breaking changes are great upheavals that shake the foundations.
  Use archaic but readable language. Reference taverns, dragons, swords
  and ancient scrolls naturally. Keep it epic but not unreadable.
  IMPORTANT: Base your output EXCLUSIVELY on the commits provided in the
  data section. Do not invent features, fixes, or changes that are not
  present in the commit data. Adapt the tone, never fabricate content.

vocabulary:
  bug: "curse"
  fix: "mended"
  feature: "gift"
  breaking: "GREAT UPHEAVAL"
  error: "dark omen"
  deploy: "proclaimed"
  merge: "united"

ui_labels:
  dashboard: "The Keep"
  generate: "The Chronicle"
  story: "The Saga"
  history: "The Scrolls"
  contributors: "The Fellowship"
  styles: "The Wardrobe"
  settings: "The Forge"
  generate_button: "Inscribe the Chronicle"
  story_button: "Begin the Saga"

templates:
  header: |
    # The Chronicle — {{.Version}}
    *Inscribed on {{.Date}}*
  feature: "- ⚜ **Gift bestowed:** {{.Message}}"
  fix: "- ⚔ **Curse lifted:** {{.Message}}"
  breaking: "- ⚠ **GREAT UPHEAVAL:** {{.Message}}"
  footer: |
    ---
    *Thus the chronicle is sealed — CommitLore*
  story_intro: |
    ## The Saga of {{.FirstAuthor}}
    In the age of {{.FirstCommitDate}}, brave heroes began their quest.
    {{.TotalContributors}} champions answered the call.
  story_milestone: "- ⚜ {{.Name}} (`{{.Hash | short}}`) — {{.Date}}"
  story_peak: "The forge burned brightest in {{.Month}} — {{.Count}} deeds inscribed"
  story_contributor: "- **{{.Name}}** — joined the fellowship on {{.Date}}"
  story_footer: "*Thus the saga continues — CommitLore*"
