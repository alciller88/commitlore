name: epic
version: 1.0.0
description: "Grand narrative chronicle style"
author: "commitlore"
llm_prompt: |
  Write the changelog as an epic narrative chronicle, as if recounting
  the legendary deeds of heroes in a fantasy saga. Every commit is a
  quest fulfilled. Every bug fix is a dragon slain. Use grandiose,
  archaic language. Address the reader as if reading from an ancient
  scroll. End with a prophetic teaser of what is to come.
templates:
  header: "📜 THE CHRONICLES OF THIS REPOSITORY"
  feature: "  And so it came to pass — {{.Author}} forged: {{.Message}}"
  fix: "  The ancient bug was vanquished by {{.Author}}: {{.Message}}"
  breaking: "  ⚡ The old ways were shattered: {{.Message}}"
  footer: "Thus ends another chapter in the saga."
  story_intro: "📜 THE SAGA BEGINS\n\nIn the age of {{.FirstCommitDate}}, the great {{.FirstAuthor}} laid the first stone.\nFrom that day, {{.TotalCommits}} deeds were recorded. {{.TotalContributors}} heroes answered the call."
  story_milestone: "  ⚡ A new era dawned: {{.Name}} — forged on {{.Date}}"
  story_peak: "  🔥 The fires of creation burned brightest in {{.Month}}: {{.Count}} deeds"
  story_contributor: "  ⚔️  {{.Name}} joined the fellowship on {{.Date}}"
  story_footer: "Thus the saga continues. The next chapter awaits."
vocabulary:
  bug: "ancient curse"
  fix: "vanquish"
  feature: "legendary artifact"
  added: "forged"
  removed: "banished"
  updated: "reforged"
  commit: "deed"
  merge: "union of realms"
theme:
  mode: "dark"
  colors:
    primary: "#d4af37"
    secondary: "#c0962c"
    background: "#0a0a0f"
    surface: "#1a1520"
    text: "#f0e8d8"
    accent: "#8b6914"
    border: "#d4af37"
  typography:
    font_family: "'Palatino Linotype', 'Book Antiqua', Palatino, serif"
    font_size_base: "15px"
    font_size_header: "26px"
    font_size_code: "12px"
  card_style: "bordered"
  animations: true
  custom_css: |
    h1, h2 { text-shadow: 0 0 10px rgba(212, 175, 55, 0.3); }
terminal:
  colors:
    header: "yellow"
    feature: "yellow"
    fix: "green"
    breaking: "red"
    footer: "yellow"
  decorators:
    separator: "⚜═══════════════════════════════════⚜"
    bullet: "⚜"
    indent: "  ║ "
  density: "verbose"
