name: "patchnotes"
version: "2.0.0"
description: "Notas de parche estilo estudio de videojuegos. Estética gaming profesional, púrpura y dorado."
author: "CommitLore"
language: "es"
tags: ["gaming", "videogame", "rpg", "dramatic", "fun"]
preview_url: ""
homepage: ""

theme:
  mode: "dark"
  colors:
    primary: "#7C6FCD"
    secondary: "#9B8EC4"
    background: "#1A1B2E"
    surface: "#242640"
    text: "#E8E8F0"
    accent: "#F0A500"
    border: "#3D3B6E"
  typography:
    font_family: "'Rajdhani', system-ui, sans-serif"
    font_size_base: "13px"
    font_size_header: "22px"
    font_size_code: "12px"
  logo: |
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M208,64H48A40,40,0,0,0,8,104v56a40,40,0,0,0,40,40H208a40,40,0,0,0,40-40V104A40,40,0,0,0,208,64ZM96,152H80v16a8,8,0,0,1-16,0V152H48a8,8,0,0,1,0-16H64V120a8,8,0,0,1,16,0v16H96a8,8,0,0,1,0,16Zm72,8a12,12,0,1,1,12-12A12,12,0,0,1,168,160Zm32-32a12,12,0,1,1,12-12A12,12,0,0,1,200,128Z"/></svg>
  header_image: ""
  card_style: "bordered"
  animations: true
  custom_css: ""
  window_controls:
    default: "#3D3B6E"
    close: "#FF4444"
    minimize: "#F0A500"
    maximize: "#7C6FCD"

terminal:
  colors:
    header: "magenta"
    feature: "cyan"
    fix: "green"
    breaking: "red"
    footer: "white"
  decorators:
    separator: "═══════════════════════════════════════"
    bullet: "▸"
    indent: "  "
  density: "normal"

llm_prompt: |
  Eres un redactor de notas de parche al estilo de un estudio profesional de videojuegos.
  Analiza los commits y agrúpalos en categorías lógicas según lo que realmente hacen — NO
  uses categorías predefinidas como Jugabilidad o Interfaz a menos que los commits se
  relacionen genuinamente con un juego. Infiere las categorías correctas a partir del
  contenido: si los commits son sobre una herramienta CLI, usa categorías como
  Características, Correcciones, Rendimiento, Cambios Importantes. Si son sobre una
  aplicación web, usa Frontend, Backend, API, etc. Deja que el contenido dicte las categorías.
  Escribe cada entrada en un tono claro y cercano al jugador: "Corregido", "Añadido",
  "Mejorado", "Ajustado". Profesional pero accesible, como Riot Games o Blizzard — pero
  adaptado a lo que sea el proyecto real.
  Responde siempre en español.
  IMPORTANTE: Basa tu respuesta EXCLUSIVAMENTE en los commits proporcionados en la sección de datos. No inventes funciones, correcciones ni cambios que no estén presentes en los datos. Adapta el tono y las categorías al contenido, nunca fabriques.

vocabulary:
  bug: "problema"
  fix: "corregido"
  feature: "añadido"
  breaking: "IMPORTANTE"
  error: "error"

ui_labels:
  dashboard: "Centro"
  generate: "Notas de Parche"
  story: "Diario Dev"
  history: "Registro de Commits"
  contributors: "Equipo Dev"
  styles: "Temas"
  settings: "Opciones"
  generate_button: "Desplegar Parche"
  story_button: "Escribir el Diario"
  marketplace: "Tienda"

icons:
  feature: "★"
  fix: "✔"
  breaking: "⚠"
  chore: "⚙"
  docs: "📋"
  test: "🧪"
  story_peak: "🔥"
  bullet: "▸"
  separator: "═══════════════════════════════════════"

templates:
  header: |
    # Notas de Parche — {{.Version}}
    *Publicado el {{.Date}}*
  feature: "- **Añadido:** {{.Message}}"
  fix: "- **Corregido:** {{.Message}}"
  breaking: "- ⚠ **IMPORTANTE:** {{.Message}}"
  footer: |
    ---
    *Notas de parche generadas por CommitLore*
  story_intro: |
    ## Diario Dev
    Desde {{.FirstCommitDate}} — {{.TotalContributors}} desarrolladores en el equipo.
  story_milestone: "- {{.Name}} (`{{.Hash | short}}`)"
  story_peak: "Pico de desarrollo: {{.Month}} — {{.Count}} commits"
  story_contributor: "- **{{.Name}}** — se unió el {{.Date}}"
  story_footer: "*Fin del diario dev — CommitLore*"

html_template_story: |
  <!DOCTYPE html>
  <html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diario Dev — {{.RepoName}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: {{.Theme.Typography.FontSizeBase}}; }
      body {
        font-family: {{safeCSS .Theme.Typography.FontFamily}};
        background: {{.Theme.Colors.Background}};
        color: {{.Theme.Colors.Text}};
        line-height: 1.6;
        min-height: 100vh;
      }
      a { color: {{.Theme.Colors.Primary}}; text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Fade-in animations */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(22px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-in {
        opacity: 0;
        animation: fadeInUp 0.55s ease forwards;
      }
      .fade-in.visible { opacity: 1; }

      /* Header banner */
      .dd-header {
        min-height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 8px;
        background: linear-gradient(135deg, {{.Theme.Colors.Primary}} 0%, {{.Theme.Colors.Background}} 100%);
        position: relative;
        overflow: hidden;
        padding: 32px 24px;
      }
      .dd-header::before {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          45deg,
          transparent,
          transparent 40px,
          color-mix(in srgb, {{.Theme.Colors.Primary}} 6%, transparent) 40px,
          color-mix(in srgb, {{.Theme.Colors.Primary}} 6%, transparent) 41px
        );
        pointer-events: none;
      }
      .dd-header-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        text-align: center;
      }
      .dd-header-eyebrow {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 65%, transparent);
      }
      .dd-header-title {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: {{.Theme.Colors.Text}};
        line-height: 1;
        text-shadow: 0 2px 16px color-mix(in srgb, {{.Theme.Colors.Primary}} 70%, transparent);
      }
      .dd-header-repo {
        font-size: 15px;
        font-weight: 600;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 80%, transparent);
        letter-spacing: 0.06em;
      }
      .dd-header-meta {
        display: flex;
        gap: 14px;
        align-items: center;
        font-size: 12px;
        font-weight: 500;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 55%, transparent);
        letter-spacing: 0.05em;
        margin-top: 2px;
      }
      .dd-header-meta-sep { opacity: 0.4; }

      /* Layout */
      .dd-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 48px 32px 88px;
      }

      /* Section label */
      .dd-section-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: {{.Theme.Colors.Primary}};
        margin-bottom: 18px;
        padding-bottom: 8px;
        border-bottom: 2px solid {{.Theme.Colors.Primary}};
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .dd-section-label::before {
        content: "//";
        opacity: 0.45;
      }

      /* Season stats card — 4-up */
      .dd-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 48px;
      }
      @media (max-width: 680px) {
        .dd-stats { grid-template-columns: repeat(2, 1fr); }
      }
      .dd-stat-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 28%, transparent);
        border-radius: 8px;
        padding: 20px 16px;
        text-align: center;
      }
      .dd-stat-value {
        font-size: 28px;
        font-weight: 700;
        color: {{.Theme.Colors.Primary}};
        letter-spacing: -0.01em;
        line-height: 1;
        margin-bottom: 6px;
        word-break: break-word;
      }
      .dd-stat-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 55%, transparent);
      }

      /* Narrative */
      .dd-narrative {
        max-width: 740px;
        margin: 0 auto 52px;
        font-size: 14px;
        line-height: 1.8;
      }
      .dd-narrative h1, .dd-narrative h2, .dd-narrative h3 {
        color: {{.Theme.Colors.Text}};
        font-weight: 700;
        margin-bottom: 12px;
        margin-top: 28px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
      }
      .dd-narrative h1 { font-size: 22px; margin-top: 0; }
      .dd-narrative h2 { font-size: 17px; color: {{.Theme.Colors.Primary}}; }
      .dd-narrative h3 { font-size: 14px; color: {{.Theme.Colors.Primary}}; }
      .dd-narrative p { color: {{.Theme.Colors.Text}}; margin-bottom: 14px; }
      .dd-narrative ul, .dd-narrative ol { padding-left: 20px; margin-bottom: 14px; }
      .dd-narrative li { line-height: 1.8; margin-bottom: 4px; color: {{.Theme.Colors.Text}}; }
      .dd-narrative strong { font-weight: 700; color: {{.Theme.Colors.Text}}; }
      .dd-narrative em { color: {{.Theme.Colors.Secondary}}; }
      .dd-narrative code {
        background: {{.Theme.Colors.Surface}};
        border-radius: 4px;
        padding: 1px 5px;
        font-size: {{.Theme.Typography.FontSizeCode}};
        color: {{.Theme.Colors.Primary}};
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .dd-narrative pre {
        background: {{.Theme.Colors.Surface}};
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
        margin-bottom: 16px;
      }
      .dd-narrative pre code { background: none; padding: 0; color: {{.Theme.Colors.Text}}; }
      .dd-narrative hr {
        border: none;
        border-top: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 28%, transparent);
        margin: 24px 0;
      }
      .dd-narrative blockquote {
        border-left: 3px solid {{.Theme.Colors.Primary}};
        padding-left: 16px;
        color: {{.Theme.Colors.Secondary}};
        margin: 0 0 14px;
      }

      /* Activity chart */
      .dd-chart-card {
        background: {{.Theme.Colors.Surface}};
        border-radius: 8px;
        padding: 24px;
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 20%, transparent);
        margin-bottom: 48px;
      }
      .dd-chart-title {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: {{.Theme.Colors.Primary}};
        margin-bottom: 20px;
      }
      .dd-chart-wrap {
        position: relative;
        height: 220px;
      }

      /* Monthly dev blog entries */
      .dd-entries {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 52px;
      }
      .dd-entry {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 20%, transparent);
        border-left: 3px solid {{.Theme.Colors.Primary}};
        border-radius: 0 8px 8px 0;
        padding: 20px 24px;
      }
      .dd-entry-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
      }
      .dd-entry-month {
        font-size: 17px;
        font-weight: 700;
        color: {{.Theme.Colors.Text}};
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .dd-entry-count {
        font-size: 12px;
        font-weight: 700;
        color: {{.Theme.Colors.Primary}};
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 12%, transparent);
        border-radius: 4px;
        padding: 2px 8px;
        white-space: nowrap;
      }
      .dd-entry-body {
        font-size: 13px;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 70%, transparent);
        line-height: 1.7;
      }
      .dd-entry-bar {
        margin-top: 12px;
        height: 4px;
        border-radius: 2px;
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 18%, transparent);
        overflow: hidden;
      }
      .dd-entry-bar-fill {
        height: 100%;
        border-radius: 2px;
        background: {{.Theme.Colors.Primary}};
        transition: width 0.8s ease;
      }

      /* Contributors — Dev Team grid */
      .dd-contributors {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 12px;
        margin-bottom: 52px;
      }
      .dd-contributor-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 20%, transparent);
        border-radius: 8px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .dd-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: {{.Theme.Colors.Primary}};
        color: {{.Theme.Colors.Background}};
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: 0.02em;
      }
      .dd-contributor-info {}
      .dd-contributor-name {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        line-height: 1.2;
      }
      .dd-contributor-count {
        font-size: 11px;
        color: {{.Theme.Colors.Primary}};
        font-weight: 600;
        margin-top: 2px;
      }
      .dd-contributor-joined {
        font-size: 10px;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 45%, transparent);
        margin-top: 2px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Tags / Milestones */
      .dd-tags {
        margin-bottom: 52px;
      }
      .dd-tag-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 15%, transparent);
        font-size: 13px;
      }
      .dd-tag-row:last-child { border-bottom: none; }
      .dd-tag-name {
        font-weight: 700;
        color: {{.Theme.Colors.Primary}};
        min-width: 110px;
        letter-spacing: 0.04em;
      }
      .dd-tag-hash {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 10%, transparent);
        border-radius: 4px;
        padding: 1px 6px;
      }
      .dd-tag-date {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        margin-left: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Footer */
      .dd-footer {
        border-top: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 30%, transparent);
        padding-top: 24px;
        margin-top: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 500;
        color: {{.Theme.Colors.Secondary}};
        letter-spacing: 0.03em;
      }
      .dd-footer-logo {
        display: flex;
        align-items: center;
        color: {{.Theme.Colors.Secondary}};
        width: 24px;
        height: 24px;
        flex-shrink: 0;
      }
      .dd-footer-logo svg { width: 24px; height: 24px; }
    </style>
  </head>
  <body>

    <header class="dd-header">
      <div class="dd-header-inner">
        <div class="dd-header-eyebrow">{{.RepoName}}</div>
        <div class="dd-header-title">Diario Dev</div>
        {{if or .FirstDate .Generated}}
        <div class="dd-header-meta">
          {{if .FirstDate}}<span>{{.FirstDate}}</span>{{end}}
          {{if and .FirstDate .Generated}}<span class="dd-header-meta-sep">→</span>{{end}}
          {{if .Generated}}<span>{{.Generated}}</span>{{end}}
        </div>
        {{end}}
      </div>
    </header>

    <main class="dd-page">

      {{/* Estadísticas de temporada — 4 tarjetas */}}
      <div class="dd-section-label fade-in" style="animation-delay:0.05s">Estadísticas de Temporada</div>
      <div class="dd-stats fade-in" style="animation-delay:0.1s">
        <div class="dd-stat-card">
          <div class="dd-stat-value">{{.TotalCommits}}</div>
          <div class="dd-stat-label">Commits Totales</div>
        </div>
        <div class="dd-stat-card">
          <div class="dd-stat-value">{{len .Contributors}}</div>
          <div class="dd-stat-label">Contribuidores</div>
        </div>
        <div class="dd-stat-card">
          <div class="dd-stat-value" style="font-size:16px;padding-top:6px">{{.FirstDate}}</div>
          <div class="dd-stat-label">Primer Commit</div>
        </div>
        <div class="dd-stat-card" id="dd-peak-stat">
          {{if .Peaks}}
          <div class="dd-stat-value" style="font-size:16px;padding-top:6px" id="dd-peak-month">—</div>
          {{else}}
          <div class="dd-stat-value">—</div>
          {{end}}
          <div class="dd-stat-label">Más Activo</div>
        </div>
      </div>

      {{/* Narrativa */}}
      {{if .Content}}
      <div class="dd-narrative fade-in" style="animation-delay:0.15s">{{.Content}}</div>
      {{end}}

      {{/* Gráfico de actividad */}}
      {{if .Peaks}}
      <div class="dd-section-label fade-in" style="animation-delay:0.2s">Actividad de Commits</div>
      <div class="dd-chart-card fade-in" style="animation-delay:0.25s">
        <div class="dd-chart-title">Commits Mensuales</div>
        <div class="dd-chart-wrap">
          <canvas id="ddActivityChart"></canvas>
        </div>
      </div>

      <script>
      (function() {
        function hexToRgba(hex, alpha) {
          hex = hex.replace('#', '');
          if (hex.length === 3) hex = hex.split('').map(function(c){return c+c;}).join('');
          var r = parseInt(hex.substring(0,2),16);
          var g = parseInt(hex.substring(2,4),16);
          var b = parseInt(hex.substring(4,6),16);
          return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
        }
        var labels  = [{{range .Peaks}}"{{.Month}}",{{end}}];
        var data    = [{{range .Peaks}}{{.Count}},{{end}}];
        var maxVal  = Math.max.apply(null, data) || 1;

        /* Rellenar estadística de mes más activo */
        var peakIdx = data.indexOf(maxVal);
        var peakEl  = document.getElementById("dd-peak-month");
        if (peakEl && labels[peakIdx]) {
          peakEl.textContent = labels[peakIdx];
        }

        /* Barras en tarjetas de entrada */
        var fills = document.querySelectorAll(".dd-entry-bar-fill");
        fills.forEach(function(el) {
          var pct = el.getAttribute("data-pct") || "0";
          el.style.width = pct + "%";
        });

        /* Gráfico */
        var ctx = document.getElementById("ddActivityChart");
        if (ctx && typeof Chart !== "undefined") {
          setTimeout(function() {
            try {
              new Chart(ctx, {
              type: "bar",
              data: {
                labels: labels,
                datasets: [{
                  label: "Commits",
                  data: data,
                  backgroundColor: "{{.Theme.Colors.Primary}}",
                  borderRadius: 4,
                  borderSkipped: false
                }]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                  x: {
                    grid: { color: hexToRgba("{{.Theme.Colors.Primary}}", 0.12) },
                    ticks: {
                      color: "{{.Theme.Colors.Secondary}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 }
                    }
                  },
                  y: {
                    grid: { color: hexToRgba("{{.Theme.Colors.Primary}}", 0.12) },
                    ticks: {
                      color: "{{.Theme.Colors.Secondary}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 },
                      precision: 0
                    }
                  }
                }
              }
            });
            } catch(e) { console.error("Chart error:", e); }
          }, 100);
        }
      })();
      </script>

      {{/* Entradas mensuales del diario dev */}}
      <div class="dd-section-label fade-in" style="animation-delay:0.3s">Entradas Mensuales</div>
      <div class="dd-entries fade-in" style="animation-delay:0.35s">
        {{$peaks := .Peaks}}
        {{$maxCount := 1}}
        {{range $peaks}}{{if gt .Count $maxCount}}{{$maxCount = .Count}}{{end}}{{end}}
        {{range $peaks}}
        {{$pct := 0.0}}
        {{if gt $maxCount 0}}{{$pct = mul (divf .Count $maxCount) 100.0}}{{end}}
        <div class="dd-entry">
          <div class="dd-entry-header">
            <div class="dd-entry-month">{{.Month}}</div>
            <div class="dd-entry-count">{{.Count}} commits</div>
          </div>
          <div class="dd-entry-body">
            {{if ge .Count (divi $maxCount 2)}}
            Sprint de desarrollo intenso — el equipo lo dio todo este mes.
            {{else}}
            Progreso constante. Mejoras incrementales desplegadas durante el mes.
            {{end}}
          </div>
          <div class="dd-entry-bar">
            <div class="dd-entry-bar-fill" data-pct="{{$pct}}"></div>
          </div>
        </div>
        {{end}}
      </div>
      {{end}}{{/* end .Peaks */}}

      {{/* Hitos / Tags */}}
      {{if .Tags}}
      <div class="dd-section-label fade-in" style="animation-delay:0.4s">Hitos</div>
      <div class="dd-tags fade-in" style="animation-delay:0.45s">
        {{range .Tags}}
        <div class="dd-tag-row">
          <span class="dd-tag-name">{{.Name}}</span>
          <span class="dd-tag-hash">{{.Hash}}</span>
          <span class="dd-tag-date">{{.Date}}</span>
        </div>
        {{end}}
      </div>
      {{end}}

      {{/* Equipo Dev — cuadrícula de contribuidores */}}
      {{if .Contributors}}
      <div class="dd-section-label fade-in" style="animation-delay:0.5s">Equipo Dev</div>
      <div class="dd-contributors fade-in" style="animation-delay:0.55s">
        {{range .Contributors}}
        <div class="dd-contributor-card">
          <div class="dd-avatar">{{initials .Name}}</div>
          <div class="dd-contributor-info">
            <div class="dd-contributor-name">{{.Name}}</div>
            <div class="dd-contributor-count">{{.Count}} commits</div>
            {{if .Date}}<div class="dd-contributor-joined">Desde {{.Date}}</div>{{end}}
          </div>
        </div>
        {{end}}
      </div>
      {{end}}

      {{if .Contributors}}
      <div class="dd-section-label fade-in" style="animation-delay:0.58s">Ranking de Contribuidores</div>
      <div class="dd-chart-card fade-in" style="animation-delay:0.6s">
        <div style="position: relative; height: 220px;">
          <canvas id="pn-contrib-chart"></canvas>
        </div>
      </div>

      <script>
      (function() {
        function hexToRgba(hex, alpha) {
          hex = hex.replace('#', '');
          if (hex.length === 3) hex = hex.split('').map(function(c){return c+c;}).join('');
          var r = parseInt(hex.substring(0,2),16);
          var g = parseInt(hex.substring(2,4),16);
          var b = parseInt(hex.substring(4,6),16);
          return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
        }
        var contribNames  = [{{range .Contributors}}"{{.Name}}",{{end}}];
        var contribCounts = [{{range .Contributors}}{{.Count}},{{end}}];
        var ctx = document.getElementById("pn-contrib-chart");
        if (ctx && contribNames.length > 0 && typeof Chart !== "undefined") {
          setTimeout(function() {
            try {
              new Chart(ctx, {
                type: "bar",
                data: {
                  labels: contribNames,
                  datasets: [{
                    label: "Commits",
                    data: contribCounts,
                    backgroundColor: "{{.Theme.Colors.Accent}}",
                    borderRadius: 3,
                    borderSkipped: false
                  }]
                },
                options: {
                  indexAxis: "y",
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: { legend: { display: false } },
                  scales: {
                    x: {
                      beginAtZero: true,
                      grid: { color: hexToRgba("{{.Theme.Colors.Primary}}", 0.12) },
                      ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 } }
                    },
                    y: {
                      grid: { display: false },
                      ticks: { color: "{{.Theme.Colors.Text}}", font: { family: "{{.Theme.Typography.FontFamily}}", size: 11 } }
                    }
                  }
                }
              });
            } catch(e) { console.error("Contrib chart error:", e); }
          }, 100);
        }
      })();
      </script>
      {{end}}

      <footer class="dd-footer fade-in" style="animation-delay:0.65s">
        {{if .Theme.Logo}}
        <div class="dd-footer-logo">{{safeHTML .Theme.Logo}}</div>
        {{end}}
        <span>Diario Dev generado por CommitLore</span>
      </footer>

    </main>

    <script>
    (function() {
      var els = document.querySelectorAll(".fade-in");
      if ("IntersectionObserver" in window) {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.style.animationPlayState = "running";
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.08 });
        els.forEach(function(el) {
          el.style.animationPlayState = "paused";
          obs.observe(el);
        });
      } else {
        els.forEach(function(el) { el.classList.add("visible"); });
      }
      setTimeout(function() {
        els.forEach(function(el) {
          el.style.animationPlayState = 'running';
          el.classList.add('visible');
        });
      }, 300);
    })();
    </script>
  </body>
  </html>

html_template_changelog: |
  <!DOCTYPE html>
  <html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}} — {{.RepoName}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: {{.Theme.Typography.FontSizeBase}}; }
      body {
        font-family: {{safeCSS .Theme.Typography.FontFamily}};
        background: {{.Theme.Colors.Background}};
        color: {{.Theme.Colors.Text}};
        line-height: 1.6;
        min-height: 100vh;
      }
      a { color: {{.Theme.Colors.Primary}}; text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Animations */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-in {
        opacity: 0;
        animation: fadeIn 0.55s ease forwards;
      }
      .fade-in.visible { opacity: 1; }

      /* Header banner */
      .pn-header {
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 6px;
        background: linear-gradient(135deg, {{.Theme.Colors.Primary}} 0%, {{.Theme.Colors.Background}} 100%);
        position: relative;
        overflow: hidden;
      }
      .pn-header::before {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          90deg,
          transparent,
          transparent 60px,
          color-mix(in srgb, {{.Theme.Colors.Primary}} 8%, transparent) 60px,
          color-mix(in srgb, {{.Theme.Colors.Primary}} 8%, transparent) 61px
        );
        pointer-events: none;
      }
      .pn-header-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .pn-header-logo {
        color: {{.Theme.Colors.Text}};
        display: flex;
        align-items: center;
        margin-bottom: 2px;
        opacity: 0.9;
      }
      .pn-header-logo svg { width: 28px; height: 28px; }
      .pn-header-title {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: {{.Theme.Colors.Text}};
        line-height: 1;
        text-shadow: 0 2px 12px color-mix(in srgb, {{.Theme.Colors.Primary}} 60%, transparent);
      }
      .pn-header-meta {
        display: flex;
        gap: 16px;
        align-items: center;
        font-size: 13px;
        font-weight: 500;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 70%, transparent);
        letter-spacing: 0.04em;
      }
      .pn-header-version {
        color: {{.Theme.Colors.Primary}};
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 0.08em;
      }

      /* Layout */
      .pn-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 40px 32px 80px;
      }

      /* Section label */
      .pn-section-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: {{.Theme.Colors.Primary}};
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid {{.Theme.Colors.Primary}};
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .pn-section-label::before {
        content: "//";
        opacity: 0.5;
      }

      /* Highlights — top 3 items */
      .pn-highlights {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 48px;
      }
      .pn-highlight-card {
        background: {{.Theme.Colors.Surface}};
        border-left: 3px solid {{.Theme.Colors.Primary}};
        border-radius: 0 8px 8px 0;
        padding: 16px 20px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
      }
      .pn-highlight-icon {
        font-size: 20px;
        line-height: 1;
        flex-shrink: 0;
        margin-top: 1px;
        color: {{.Theme.Colors.Primary}};
      }
      .pn-highlight-content {}
      .pn-highlight-type {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: {{.Theme.Colors.Primary}};
        margin-bottom: 4px;
      }
      .pn-highlight-msg {
        font-size: 15px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        line-height: 1.4;
      }
      .pn-highlight-meta {
        font-size: 11px;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 55%, transparent);
        margin-top: 4px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Narrative */
      .pn-narrative {
        max-width: 720px;
        margin: 0 auto 48px;
      }
      .pn-narrative h1, .pn-narrative h2, .pn-narrative h3 {
        color: {{.Theme.Colors.Text}};
        font-weight: 700;
        margin-bottom: 12px;
        margin-top: 28px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
      }
      .pn-narrative h1 { font-size: 22px; margin-top: 0; }
      .pn-narrative h2 { font-size: 17px; color: {{.Theme.Colors.Primary}}; }
      .pn-narrative h3 { font-size: 14px; color: {{.Theme.Colors.Primary}}; }
      .pn-narrative p {
        line-height: 1.8;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 14px;
        font-size: 14px;
      }
      .pn-narrative ul, .pn-narrative ol {
        padding-left: 20px;
        margin-bottom: 14px;
      }
      .pn-narrative li { line-height: 1.8; margin-bottom: 4px; color: {{.Theme.Colors.Text}}; }
      .pn-narrative strong { font-weight: 700; color: {{.Theme.Colors.Text}}; }
      .pn-narrative em { color: {{.Theme.Colors.Secondary}}; }
      .pn-narrative code {
        background: {{.Theme.Colors.Surface}};
        border-radius: 4px;
        padding: 1px 5px;
        font-size: {{.Theme.Typography.FontSizeCode}};
        color: {{.Theme.Colors.Primary}};
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .pn-narrative pre {
        background: {{.Theme.Colors.Surface}};
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
        margin-bottom: 16px;
      }
      .pn-narrative pre code { background: none; padding: 0; color: {{.Theme.Colors.Text}}; }
      .pn-narrative hr {
        border: none;
        border-top: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 30%, transparent);
        margin: 24px 0;
      }
      .pn-narrative blockquote {
        border-left: 3px solid {{.Theme.Colors.Primary}};
        padding-left: 16px;
        color: {{.Theme.Colors.Secondary}};
        margin: 0 0 14px;
      }

      /* Commit groups */
      .pn-groups {
        margin-bottom: 48px;
      }
      .pn-item-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 9px 0;
        border-bottom: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 15%, transparent);
        font-size: 13px;
        color: {{.Theme.Colors.Text}};
      }
      .pn-item-row:last-child { border-bottom: none; }
      .pn-item-icon {
        font-size: 14px;
        color: {{.Theme.Colors.Primary}};
        flex-shrink: 0;
        margin-top: 1px;
        min-width: 18px;
        text-align: center;
      }
      .pn-item-msg {
        flex: 1;
        line-height: 1.5;
      }
      .pn-item-hash {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 10px;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 45%, transparent);
        flex-shrink: 0;
        align-self: center;
      }

      /* Charts */
      .pn-charts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 48px;
      }
      .pn-chart-card {
        background: {{.Theme.Colors.Surface}};
        border-radius: 8px;
        padding: 24px;
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 20%, transparent);
      }
      .pn-chart-title {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: {{.Theme.Colors.Primary}};
        margin-bottom: 20px;
      }
      .pn-chart-wrap {
        position: relative;
        height: 200px;
      }

      /* Stats row */
      .pn-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 48px;
      }
      .pn-stat-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 25%, transparent);
        border-radius: 8px;
        padding: 20px 24px;
        text-align: center;
      }
      .pn-stat-value {
        font-size: 32px;
        font-weight: 700;
        color: {{.Theme.Colors.Primary}};
        letter-spacing: -0.02em;
        line-height: 1;
        margin-bottom: 6px;
      }
      .pn-stat-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: color-mix(in srgb, {{.Theme.Colors.Text}} 60%, transparent);
      }

      /* Contributors grid */
      .pn-contributors {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
        margin-bottom: 48px;
      }
      .pn-contributor-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 20%, transparent);
        border-radius: 8px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .pn-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: {{.Theme.Colors.Primary}};
        color: {{.Theme.Colors.Background}};
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: 0.02em;
      }
      .pn-contributor-info {}
      .pn-contributor-name {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        line-height: 1.2;
      }
      .pn-contributor-count {
        font-size: 11px;
        color: {{.Theme.Colors.Primary}};
        font-weight: 600;
        margin-top: 2px;
      }

      /* Tags / Milestones */
      .pn-tags {
        margin-bottom: 48px;
      }
      .pn-tag-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 15%, transparent);
        font-size: 13px;
      }
      .pn-tag-row:last-child { border-bottom: none; }
      .pn-tag-name {
        font-weight: 700;
        color: {{.Theme.Colors.Primary}};
        min-width: 100px;
        letter-spacing: 0.04em;
      }
      .pn-tag-hash {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 10%, transparent);
        border-radius: 4px;
        padding: 1px 6px;
      }
      .pn-tag-date {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        margin-left: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Footer */
      .pn-footer {
        border-top: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 30%, transparent);
        padding-top: 24px;
        margin-top: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 500;
        color: {{.Theme.Colors.Secondary}};
        letter-spacing: 0.02em;
      }
      .pn-footer-logo {
        display: flex;
        align-items: center;
        color: {{.Theme.Colors.Secondary}};
        width: 24px;
        height: 24px;
        flex-shrink: 0;
      }
      .pn-footer-logo svg { width: 24px; height: 24px; }
    </style>
  </head>
  <body>

    <header class="pn-header">
      <div class="pn-header-inner">
        {{if .Theme.Logo}}
        <div class="pn-header-logo">{{safeHTML .Theme.Logo}}</div>
        {{end}}
        <div class="pn-header-title">Notas de Parche</div>
        <div class="pn-header-meta">
          {{if .Version}}<span class="pn-header-version">{{.Version}}</span>{{end}}
          {{if .Version}}{{if .Generated}}<span>·</span>{{end}}{{end}}
          {{if .Generated}}<span>{{.Generated}}</span>{{end}}
        </div>
      </div>
    </header>

    <main class="pn-page">

      {{if .Content}}
      <div class="pn-narrative fade-in">{{.Content}}</div>
      {{end}}

      {{if .Items}}
      {{/* Modo changelog */}}

      {{/* Top 3 destacados */}}
      <div class="pn-section-label fade-in" style="animation-delay:0.05s">Destacados</div>
      <div class="pn-highlights fade-in" style="animation-delay:0.1s">
        {{range $i, $item := .Items}}{{if lt $i 3}}
        <div class="pn-highlight-card">
          <div class="pn-highlight-icon">{{$item.Icon}}</div>
          <div class="pn-highlight-content">
            <div class="pn-highlight-type">{{$item.Type}}</div>
            <div class="pn-highlight-msg">{{$item.Message}}</div>
            <div class="pn-highlight-meta">{{$item.Hash}} · {{$item.Author}}</div>
          </div>
        </div>
        {{end}}{{end}}
      </div>

      {{/* Fila de estadísticas */}}
      <div class="pn-stats fade-in" style="animation-delay:0.15s">
        <div class="pn-stat-card">
          <div class="pn-stat-value">{{len .Items}}</div>
          <div class="pn-stat-label">Commits Totales</div>
        </div>
        <div class="pn-stat-card">
          <div class="pn-stat-value" id="pn-feat-count">—</div>
          <div class="pn-stat-label">Características</div>
        </div>
        <div class="pn-stat-card">
          <div class="pn-stat-value" id="pn-fix-count">—</div>
          <div class="pn-stat-label">Correcciones</div>
        </div>
      </div>

      {{/* Lista de todos los cambios */}}
      <div class="pn-section-label fade-in" style="animation-delay:0.2s">Todos los Cambios</div>
      <div class="pn-groups fade-in" style="animation-delay:0.25s">
        {{range .Items}}
        <div class="pn-item-row">
          <span class="pn-item-icon">{{.Icon}}</span>
          <span class="pn-item-msg">{{.Message}}</span>
          <span class="pn-item-hash">{{.Hash}}</span>
        </div>
        {{end}}
      </div>

      {{/* Gráfico de dona — distribución de tipos de commit */}}
      <div class="pn-section-label fade-in" style="animation-delay:0.3s">Distribución de Commits</div>
      <div class="pn-charts fade-in" style="animation-delay:0.35s; grid-template-columns: 1fr;">
        <div class="pn-chart-card" style="max-width: 440px; margin: 0 auto;">
          <div class="pn-chart-title">Tipos de Commit</div>
          <div class="pn-chart-wrap">
            <canvas id="pnTypeChart"></canvas>
          </div>
        </div>
      </div>

      <script>
      (function() {
        var items = [
          {{range .Items}}
          { type: "{{lower .Type}}" },
          {{end}}
        ];
        var counts = {};
        items.forEach(function(i) {
          counts[i.type] = (counts[i.type] || 0) + 1;
        });
        var featCount = counts["feat"] || counts["feature"] || 0;
        var fixCount  = counts["fix"] || 0;
        var el1 = document.getElementById("pn-feat-count");
        var el2 = document.getElementById("pn-fix-count");
        if (el1) el1.textContent = featCount;
        if (el2) el2.textContent = fixCount;

        var vocabMap = { {{range $k, $v := .Vocabulary}}"{{$k}}": "{{$v}}", {{end}} };
        var rawLabels = Object.keys(counts);
        var labels = rawLabels.map(function(k) { return vocabMap[k] || k; });
        var data   = rawLabels.map(function(k) { return counts[k]; });
        var palette = [
          "{{.Theme.Colors.Primary}}",
          "{{.Theme.Colors.Accent}}",
          "{{.Theme.Colors.Secondary}}",
          "#E24B4A",
          "#1D9E75",
          "#EF9F27",
          "#7F77DD"
        ];
        while (palette.length < labels.length) { palette.push(palette[palette.length - 1]); }

        var ctx = document.getElementById("pnTypeChart");
        if (ctx) {
          setTimeout(function() {
            try {
              new Chart(ctx, {
                type: "doughnut",
                data: {
                  labels: labels,
                  datasets: [{
                    data: data,
                    backgroundColor: palette.slice(0, labels.length),
                    borderWidth: 0
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                    legend: {
                      position: "right",
                      labels: {
                        color: "{{.Theme.Colors.Text}}",
                        font: { family: "{{.Theme.Typography.FontFamily}}", size: 11 },
                        padding: 12
                      }
                    }
                  }
                }
              });
            } catch(e) { console.error("Chart error:", e); }
          }, 100);
        }
      })();
      </script>

      {{end}}{{/* end .Items */}}

      {{if .Peaks}}
      {{/* Modo historia */}}

      {{/* Fila de estadísticas */}}
      <div class="pn-stats fade-in" style="animation-delay:0.05s">
        <div class="pn-stat-card">
          <div class="pn-stat-value">{{.TotalCommits}}</div>
          <div class="pn-stat-label">Commits Totales</div>
        </div>
        <div class="pn-stat-card">
          <div class="pn-stat-value">{{len .Contributors}}</div>
          <div class="pn-stat-label">Desarrolladores</div>
        </div>
        <div class="pn-stat-card">
          <div class="pn-stat-value">{{len .Tags}}</div>
          <div class="pn-stat-label">Hitos</div>
        </div>
      </div>

      {{/* Gráfico de actividad */}}
      <div class="pn-section-label fade-in" style="animation-delay:0.1s">Actividad de Desarrollo</div>
      <div class="pn-charts fade-in" style="animation-delay:0.15s; grid-template-columns: 1fr;">
        <div class="pn-chart-card">
          <div class="pn-chart-title">Actividad de Commits</div>
          <div class="pn-chart-wrap">
            <canvas id="pnActivityChart"></canvas>
          </div>
        </div>
      </div>

      <script>
      (function() {
        function hexToRgba(hex, alpha) {
          hex = hex.replace('#', '');
          if (hex.length === 3) hex = hex.split('').map(function(c){return c+c;}).join('');
          var r = parseInt(hex.substring(0,2),16);
          var g = parseInt(hex.substring(2,4),16);
          var b = parseInt(hex.substring(4,6),16);
          return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
        }
        var labels = [{{range .Peaks}}"{{.Month}}",{{end}}];
        var data   = [{{range .Peaks}}{{.Count}},{{end}}];
        var ctx    = document.getElementById("pnActivityChart");
        if (ctx) {
          setTimeout(function() {
            try {
              new Chart(ctx, {
              type: "bar",
              data: {
                labels: labels,
                datasets: [{
                  label: "Commits",
                  data: data,
                  backgroundColor: "{{.Theme.Colors.Primary}}",
                  borderRadius: 4,
                  borderSkipped: false
                }]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                  x: {
                    grid: { color: hexToRgba("{{.Theme.Colors.Primary}}", 0.15) },
                    ticks: {
                      color: "{{.Theme.Colors.Secondary}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 }
                    }
                  },
                  y: {
                    grid: { color: hexToRgba("{{.Theme.Colors.Primary}}", 0.15) },
                    ticks: {
                      color: "{{.Theme.Colors.Secondary}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 }
                    }
                  }
                }
              }
            });
            } catch(e) { console.error("Chart error:", e); }
          }, 100);
        }
      })();
      </script>

      {{if .Tags}}
      <div class="pn-section-label fade-in" style="animation-delay:0.2s">Hitos</div>
      <div class="pn-tags fade-in" style="animation-delay:0.25s">
        {{range .Tags}}
        <div class="pn-tag-row">
          <span class="pn-tag-name">{{.Name}}</span>
          <span class="pn-tag-hash">{{.Hash}}</span>
          <span class="pn-tag-date">{{.Date}}</span>
        </div>
        {{end}}
      </div>
      {{end}}

      {{if .Contributors}}
      <div class="pn-section-label fade-in" style="animation-delay:0.3s">Equipo Dev</div>
      <div class="pn-contributors fade-in" style="animation-delay:0.35s">
        {{range .Contributors}}
        <div class="pn-contributor-card">
          <div class="pn-avatar">{{initials .Name}}</div>
          <div class="pn-contributor-info">
            <div class="pn-contributor-name">{{.Name}}</div>
            <div class="pn-contributor-count">{{.Count}} commits</div>
          </div>
        </div>
        {{end}}
      </div>
      {{end}}

      {{end}}{{/* end .Peaks */}}

      <footer class="pn-footer fade-in">
        {{if .Theme.Logo}}
        <div class="pn-footer-logo">{{safeHTML .Theme.Logo}}</div>
        {{end}}
        <span>Notas de parche generadas por CommitLore</span>
      </footer>

    </main>

    <script>
    (function() {
      var els = document.querySelectorAll(".fade-in");
      if ("IntersectionObserver" in window) {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.style.animationPlayState = "running";
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.1 });
        els.forEach(function(el) {
          el.style.animationPlayState = "paused";
          obs.observe(el);
        });
      } else {
        els.forEach(function(el) { el.classList.add("visible"); });
      }
      setTimeout(function() {
        els.forEach(function(el) {
          el.style.animationPlayState = 'running';
          el.classList.add('visible');
        });
      }, 300);
    })();
    </script>
  </body>
  </html>
