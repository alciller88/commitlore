name: "patchnotes"
version: "2.0.0"
description: "Game studio patch notes. Professional gaming aesthetic, purple and gold."
author: "CommitLore"
tags: ["gaming", "videogame", "rpg", "dramatic", "fun"]
preview_url: ""
homepage: ""

theme:
  mode: "dark"
  colors:
    primary: "#7C6FCD"
    secondary: "#9B8EC4"
    background: "#1A1B2E"
    surface: "#242640"
    text: "#E8E8F0"
    accent: "#F0A500"
    border: "#3D3B6E"
  typography:
    font_family: "'Rajdhani', system-ui, sans-serif"
    font_size_base: "13px"
    font_size_header: "22px"
    font_size_code: "12px"
  logo: |
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M208,64H48A40,40,0,0,0,8,104v56a40,40,0,0,0,40,40H208a40,40,0,0,0,40-40V104A40,40,0,0,0,208,64ZM96,152H80v16a8,8,0,0,1-16,0V152H48a8,8,0,0,1,0-16H64V120a8,8,0,0,1,16,0v16H96a8,8,0,0,1,0,16Zm72,8a12,12,0,1,1,12-12A12,12,0,0,1,168,160Zm32-32a12,12,0,1,1,12-12A12,12,0,0,1,200,128Z"/></svg>
  header_image: ""
  card_style: "bordered"
  animations: true
  custom_css: ""
  window_controls:
    default: "#3D3B6E"
    close: "#FF4444"
    minimize: "#F0A500"
    maximize: "#7C6FCD"

terminal:
  colors:
    header: "magenta"
    feature: "cyan"
    fix: "green"
    breaking: "red"
    footer: "white"
  decorators:
    separator: "═══════════════════════════════════════"
    bullet: "▸"
    indent: "  "
  density: "normal"

llm_prompt: |
  You are writing patch notes in the style of a professional game studio.
  Analyze the commits and group them into logical categories based on what
  they actually do — do NOT use predefined categories like Gameplay or UI
  unless the commits genuinely relate to a game. Infer the right categories
  from the content: if commits are about a CLI tool, use categories like
  Features, Fixes, Performance, Breaking Changes. If they are about a web
  app, use Frontend, Backend, API, etc. Let the content dictate the categories.
  Write each entry in a clear, player-friendly tone: "Fixed", "Added",
  "Improved", "Adjusted". Professional but approachable, like Riot Games
  or Blizzard — but adapted to whatever the actual project is.
  IMPORTANT: Base your output EXCLUSIVELY on the commits provided in the
  data section below. Do not invent features, fixes, or changes that are
  not present in the commit data. Every item must correspond to a real
  commit. Adapt the tone and categories to the content, never fabricate.

vocabulary:
  bug: "issue"
  fix: "fixed"
  feature: "added"
  breaking: "IMPORTANT"
  error: "problem"

ui_labels:
  dashboard: "Hub"
  generate: "Patch Notes"
  story: "Dev Diary"
  history: "Commit Log"
  contributors: "Dev Team"
  styles: "Themes"
  settings: "Options"
  generate_button: "Deploy Patch"
  story_button: "Write the Dev Diary"

icons:
  feature: "★"
  fix: "✔"
  breaking: "⚠"
  chore: "⚙"
  docs: "📋"
  test: "🧪"
  story_peak: "🔥"
  bullet: "▸"
  separator: "═══════════════════════════════════════"

templates:
  header: |
    # Patch Notes — {{.Version}}
    *Released {{.Date}}*
  feature: "- **Added:** {{.Message}}"
  fix: "- **Fixed:** {{.Message}}"
  breaking: "- ⚠ **IMPORTANT:** {{.Message}}"
  footer: |
    ---
    *Patch notes generated by CommitLore*
  story_intro: |
    ## Dev Diary
    From {{.FirstCommitDate}} — {{.TotalContributors}} developers on the team.
  story_milestone: "- {{.Name}} (`{{.Hash | short}}`)"
  story_peak: "Peak development: {{.Month}} — {{.Count}} commits"
  story_contributor: "- **{{.Name}}** — joined {{.Date}}"
  story_footer: "*End of dev diary — CommitLore*"
