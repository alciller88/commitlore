name: "patchnotes"
version: "2.0.0"
description: "Game studio patch notes. Professional gaming aesthetic, purple and gold."
author: "CommitLore"
tags: ["gaming", "videogame", "rpg", "dramatic", "fun"]
preview_url: ""
homepage: ""

theme:
  mode: "dark"
  colors:
    primary: "#7C6FCD"
    secondary: "#9B8EC4"
    background: "#1A1B2E"
    surface: "#242640"
    text: "#E8E8F0"
    accent: "#F0A500"
    border: "#3D3B6E"
  typography:
    font_family: "'Rajdhani', system-ui, sans-serif"
    font_size_base: "13px"
    font_size_header: "22px"
    font_size_code: "12px"
  logo: |
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M208,64H48A40,40,0,0,0,8,104v56a40,40,0,0,0,40,40H208a40,40,0,0,0,40-40V104A40,40,0,0,0,208,64ZM96,152H80v16a8,8,0,0,1-16,0V152H48a8,8,0,0,1,0-16H64V120a8,8,0,0,1,16,0v16H96a8,8,0,0,1,0,16Zm72,8a12,12,0,1,1,12-12A12,12,0,0,1,168,160Zm32-32a12,12,0,1,1,12-12A12,12,0,0,1,200,128Z"/></svg>
  header_image: ""
  card_style: "bordered"
  animations: true
  custom_css: ""
  window_controls:
    default: "#3D3B6E"
    close: "#FF4444"
    minimize: "#F0A500"
    maximize: "#7C6FCD"

terminal:
  colors:
    header: "magenta"
    feature: "cyan"
    fix: "green"
    breaking: "red"
    footer: "white"
  decorators:
    separator: "═══════════════════════════════════════"
    bullet: "▸"
    indent: "  "
  density: "normal"

llm_prompt: |
  You are writing patch notes for a video game update in the style of a
  professional game studio like Riot Games or Blizzard.
  Group changes by category: Gameplay, UI, Performance, Bug Fixes.
  Be clear and player-friendly. Highlight balance changes and bug fixes prominently.
  Use gaming conventions — "fixed", "added", "adjusted", "improved".
  Do not use corporate jargon. Tone: professional but approachable.
  Output clean markdown.

vocabulary:
  bug: "issue"
  fix: "fixed"
  feature: "added"
  breaking: "IMPORTANT"
  error: "problem"

ui_labels:
  dashboard: "Hub"
  generate: "Patch Notes"
  story: "Dev Diary"
  history: "Commit Log"
  contributors: "Dev Team"
  styles: "Themes"
  settings: "Options"

templates:
  header: |
    # Patch Notes — {{.Version}}
    *Released {{.Date}}*
  feature: "- **Added:** {{.Message}}"
  fix: "- **Fixed:** {{.Message}}"
  breaking: "- ⚠ **IMPORTANT:** {{.Message}}"
  footer: |
    ---
    *Patch notes generated by CommitLore*
  story_intro: |
    ## Dev Diary
    From {{.FirstCommitDate}} — {{.TotalContributors}} developers on the team.
  story_milestone: "- {{.Name}} (`{{.Hash | short}}`)"
  story_peak: "Peak development: {{.Month}} — {{.Count}} commits"
  story_contributor: "- **{{.Name}}** — joined {{.Date}}"
  story_footer: "*End of dev diary — CommitLore*"
