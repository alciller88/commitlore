name: patchnotes
version: 1.0.0
description: "Video game patch notes style"
author: "commitlore"
llm_prompt: |
  Write the changelog as if it were the official patch notes of a major
  video game update. Use terms like "buffed", "nerfed", "unlocked",
  "added to the game", "removed from the game", "patched".
  Be dramatic and epic. Use ALL CAPS for emphasis. Add emojis.
  Address the reader as "adventurer" or "hero".
templates:
  header: "⚔️  PATCH NOTES"
  feature: "  ✨ UNLOCKED: {{.Message}} [{{.Author}}]"
  fix: "  🛡️  PATCHED: {{.Message}} [{{.Author}}]"
  breaking: "  💀 REMOVED FROM THE GAME: {{.Message}} [{{.Author}}]"
  footer: "— Stay strong, adventurer —"
  story_intro: "⚔️  THE LEGEND BEGINS\n\nOn {{.FirstCommitDate}}, hero {{.FirstAuthor}} spawned into the world.\n{{.TotalCommits}} quests completed. {{.TotalContributors}} heroes recruited."
  story_milestone: "  🏆 ACHIEVEMENT UNLOCKED: {{.Name}} — {{.Date}}"
  story_peak: "  🔥 HOT STREAK: {{.Month}} — {{.Count}} quests completed"
  story_contributor: "  🎮 NEW PLAYER: {{.Name}} joined the party on {{.Date}}"
  story_footer: "— The game continues, adventurer —"
vocabulary:
  bug: "glitch"
  fix: "patch"
  feature: "new ability"
  added: "unlocked"
  removed: "removed from the game"
  updated: "buffed"
theme:
  mode: "dark"
  colors:
    primary: "#9b59b6"
    secondary: "#d4af37"
    background: "#1a0a2e"
    surface: "#2d1b4e"
    text: "#e8e0f0"
    accent: "#8e44ad"
    border: "#d4af37"
  typography:
    font_family: "'Press Start 2P', 'Courier New', monospace"
    font_size_base: "13px"
    font_size_header: "22px"
    font_size_code: "11px"
  card_style: "bordered"
  animations: true
terminal:
  colors:
    header: "magenta"
    feature: "yellow"
    fix: "cyan"
    breaking: "red"
    footer: "magenta"
  decorators:
    separator: "⚔═══════════════════════════════════⚔"
    bullet: "⚔️"
    indent: "  ║ "
  density: "normal"
