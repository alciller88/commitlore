        margin-left: auto;
      }
      .word-titlebar-btn {
        display: inline-block;
        width: 16px;
        height: 14px;
        background: {{.Theme.Colors.Border}};
        border: 1px solid {{.Theme.Colors.Secondary}};
        font-size: 9px;
        line-height: 12px;
        text-align: center;
        color: {{.Theme.Colors.Secondary}};
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        cursor: default;
        user-select: none;
      }

      /* Fake Word 95 toolbar */
      .word-toolbar {
        height: 28px;
        background: {{.Theme.Colors.Surface}};
        border-bottom: 1px solid {{.Theme.Colors.Border}};
        display: flex;
        align-items: center;
        padding: 0 8px;
        gap: 12px;
      }
      .word-toolbar-item {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        padding: 2px 5px;
        border: 1px solid transparent;
        cursor: default;
        user-select: none;
      }
      .word-toolbar-sep {
        width: 1px;
        height: 16px;
        background: {{.Theme.Colors.Border}};
      }

      /* Page / document area */
      .word-page-area {
        padding: 32px;
        min-height: calc(100vh - 60px);
      }
      .word-document {
        background: {{.Theme.Colors.Surface}};
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 3rem;
        border: 1px solid {{.Theme.Colors.Border}};
      }

      /* Document heading */
      .doc-title {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 22px;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 4px;
      }
      .doc-subtitle {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 24px;
      }
      .doc-divider {
        border: none;
        border-top: 1px solid {{.Theme.Colors.Border}};
        margin: 20px 0;
      }

      /* Chapter headings */
      .doc-chapter {
        margin: 28px 0 8px;
      }
      .doc-chapter-title {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 16px;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 2px;
      }
      .doc-chapter-meta {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 6px;
      }
      .doc-chapter-commentary {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        font-style: italic;
        margin-bottom: 12px;
      }

      /* Narrative content */
      .doc-narrative {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 24px;
      }
      .doc-narrative p {
        text-indent: 0;
        margin-bottom: 8px;
        line-height: 1.7;
        color: {{.Theme.Colors.Text}};
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
      }
      .doc-narrative h1, .doc-narrative h2, .doc-narrative h3 {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        color: {{.Theme.Colors.Text}};
        margin: 20px 0 8px;
        text-indent: 0;
      }
      .doc-narrative h1 { font-size: 20px; }
      .doc-narrative > h1:first-child { display: none; }
      .doc-narrative h2 { font-size: 16px; }
      .doc-narrative h3 { font-size: 14px; }
      .doc-narrative ul, .doc-narrative ol {
        list-style: disc;
        padding-left: 1.5em;
        margin-bottom: 10px;
      }
      .doc-narrative li {
        padding: 2px 0;
        border-bottom: none;
        display: list-item;
        margin-bottom: 4px;
      }
      .doc-narrative strong { color: {{.Theme.Colors.Text}}; }
      .doc-narrative em { color: {{.Theme.Colors.Secondary}}; }
      .doc-narrative code {
        background: {{.Theme.Colors.Background}};
        border: 1px solid {{.Theme.Colors.Border}};
        padding: 1px 4px;
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 12px;
        color: {{.Theme.Colors.Primary}};
      }

      /* Section label */
      .doc-section-label {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 12px;
        margin-top: 28px;
      }

      /* Chart area */
      .doc-chart-wrap {
        margin-bottom: 28px;
      }
      .doc-chart-title {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 13px;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 10px;
      }
      .doc-chart-canvas-wrap {
        position: relative;
        height: 180px;
        background: {{.Theme.Colors.Background}};
        border: 1px solid {{.Theme.Colors.Border}};
        padding: 12px;
      }

      /* Contributors table — Word style */
      .doc-contrib-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 12px;
        margin-bottom: 28px;
      }
      .doc-contrib-table th {
        border: 1px solid {{.Theme.Colors.Border}};
        padding: 6px 10px;
        text-align: left;
        color: {{.Theme.Colors.Secondary}};
        font-weight: normal;
        background: {{.Theme.Colors.Background}};
      }
      .doc-contrib-table td {
        border: 1px solid {{.Theme.Colors.Border}};
        padding: 6px 10px;
        color: {{.Theme.Colors.Text}};
        vertical-align: top;
      }

      /* Footer */
      .doc-footer {
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        margin-top: 32px;
        padding-top: 12px;
        border-top: 1px solid {{.Theme.Colors.Border}};
        display: flex;
        align-items: center;
        gap: 6px;
      }

      /* Clippy — sticky at bottom of document */
      .clippy-bubble {
        position: sticky;
        bottom: 24px;
        align-self: flex-end;
        margin-left: auto;
        margin-top: 24px;
        width: 240px;
        background: {{.Theme.Colors.Surface}};
        border: 2px solid {{.Theme.Colors.Accent}};
        padding: 10px 12px;
        font-family: 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 11px;
        color: {{.Theme.Colors.Text}};
        z-index: 100;
        line-height: 1.5;
      }
      .clippy-label {
        display: block;
        font-size: 10px;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 4px;
      }
    </style>
  </head>
  <body>

    <!-- Fake Word 95 title bar -->
    <div class="word-titlebar">
      <div class="word-titlebar-icon"></div>
      <span class="word-titlebar-name">astory.doc — Microsoft Word</span>
      <div class="word-titlebar-buttons">
        <span class="word-titlebar-btn">_</span>
        <span class="word-titlebar-btn">□</span>
        <span class="word-titlebar-btn">×</span>
      </div>
    </div>

    <!-- Fake Word 95 toolbar -->
    <div class="word-toolbar">
      <span class="word-toolbar-item">Archivo</span>
      <span class="word-toolbar-item">Editar</span>
      <span class="word-toolbar-item">Ver</span>
      <div class="word-toolbar-sep"></div>
      <span class="word-toolbar-item"><b>N</b></span>
      <span class="word-toolbar-item"><i>C</i></span>
      <span class="word-toolbar-item"><u>S</u></span>
      <div class="word-toolbar-sep"></div>
      <span class="word-toolbar-item">Normal</span>
      <span class="word-toolbar-item">Comic Sans MS</span>
      <span class="word-toolbar-item">12</span>
    </div>

    <div class="word-page-area">
      <div class="word-document">

        <div class="doc-title">{{if eq .Title "Repository Story"}}una historia supongo{{else}}{{.Title}}{{end}}</div>
        <div class="doc-subtitle">
          {{.RepoName}} &nbsp;·&nbsp; {{.Generated}}{{if .Version}} &nbsp;·&nbsp; {{.Version}}{{end}}
          {{if .TotalCommits}} &nbsp;·&nbsp; {{.TotalCommits}} commits. alguien estuvo ocupado.{{end}}
          {{if .Peaks}} &nbsp;·&nbsp; pico en {{(index .Peaks 0).Month}}{{end}}
        </div>
        <hr class="doc-divider">

        {{if .Peaks}}
        <div class="doc-section-label">los capitulos (hay {{len .Peaks}} de ellos)</div>
        {{range $i, $p := .Peaks}}
        <div class="doc-chapter">
          {{if eq $i 0}}
          <div class="doc-chapter-title">Capitulo 1: Empezo</div>
          {{else if eq $i 1}}
          <div class="doc-chapter-title">Capitulo 2: Pasaron Mas Cosas</div>
          {{else if eq $i 2}}
          <div class="doc-chapter-title">Capitulo 3: Hubo Gente Involucrada</div>
          {{else}}
          <div class="doc-chapter-title">Capitulo {{add $i 1}}: Y Asi Sucesivamente</div>
          {{end}}
          <div class="doc-chapter-meta">{{$p.Month}}</div>
          <div class="doc-chapter-commentary">si, {{$p.Count}} commits. alguien estuvo ocupado.</div>
        </div>
        {{end}}
        <hr class="doc-divider">
        {{end}}

        {{if .Content}}
        <div class="doc-narrative">{{.Content}}</div>
        <hr class="doc-divider">
        {{end}}

        {{if .Peaks}}
        <div class="doc-section-label">cuando la gente realmente trabajo</div>
        <div class="doc-chart-wrap">
          <div class="doc-chart-canvas-wrap">
            <canvas id="activityChart"></canvas>
          </div>
        </div>

        <script>
        (function() {
          var labels = [{{range .Peaks}}"{{.Month}}",{{end}}];
          var data = [{{range .Peaks}}{{.Count}},{{end}}];
          var ctx = document.getElementById("activityChart");
          if (ctx && typeof Chart !== "undefined") {
            setTimeout(function() {
              try {
                new Chart(ctx, {
                  type: "bar",
                  data: {
                    labels: labels,
                    datasets: [{
                      label: "commits",
                      data: data,
                      backgroundColor: "{{.Theme.Colors.Primary}}",
                      borderWidth: 0,
                      borderRadius: 2
                    }]
                  },
                  options: {
                    indexAxis: "y",
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                      legend: { display: false }
                    },
                    scales: {
                      x: {
                        grid: { color: "{{.Theme.Colors.Border}}" },
                        ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "'Comic Sans MS', cursive", size: 10 } }
                      },
                      y: {
                        grid: { display: false },
                        ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "'Comic Sans MS', cursive", size: 10 } }
                      }
                    }
                  }
                });
              } catch(e) { console.error("Chart error:", e); }
            }, 100);
          }
        })();
        </script>
        {{end}}

        {{if .Contributors}}
        <div class="doc-section-label">los culpables ({{len .Contributors}} de ellos)</div>
        <table class="doc-contrib-table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Commits</th>
              <th>llego</th>
            </tr>
          </thead>
          <tbody>
            {{range .Contributors}}
            <tr>
              <td>{{.Name}}</td>
              <td>{{.Count}}</td>
              <td>desde {{.Date}}</td>
            </tr>
            {{end}}
          </tbody>
        </table>
        {{end}}

        {{if .Contributors}}
        <div class="doc-section-label">quien hizo mas (supuestamente)</div>
        <div class="doc-chart-wrap">
          <div class="doc-chart-canvas-wrap">
            <canvas id="ir-contrib-chart"></canvas>
          </div>
        </div>

        <script>
        (function() {
          var contribNames  = [{{range .Contributors}}"{{.Name}}",{{end}}];
          var contribCounts = [{{range .Contributors}}{{.Count}},{{end}}];
          var ctx = document.getElementById("ir-contrib-chart");
          if (ctx && contribNames.length > 0 && typeof Chart !== "undefined") {
            setTimeout(function() {
              try {
                new Chart(ctx, {
                  type: "bar",
                  data: {
                    labels: contribNames,
                    datasets: [{
                      label: "commits",
                      data: contribCounts,
                      backgroundColor: "{{.Theme.Colors.Primary}}",
                      borderWidth: 0,
                      borderRadius: 2
                    }]
                  },
                  options: {
                    indexAxis: "y",
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                      x: {
                        beginAtZero: true,
                        grid: { color: "{{.Theme.Colors.Border}}" },
                        ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "'Comic Sans MS', cursive", size: 10 } }
                      },
                      y: {
                        grid: { display: false },
                        ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "'Comic Sans MS', cursive", size: 10 } }
                      }
                    }
                  }
                });
              } catch(e) { console.error("Contrib chart error:", e); }
            }, 100);
          }
        })();
        </script>
        {{end}}

        {{if .Tags}}
        <div class="doc-section-label">momentos notables (si los hay)</div>
        <table class="doc-contrib-table">
          <thead>
            <tr>
              <th>Etiqueta</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            {{range .Tags}}
            <tr>
              <td>{{.Name}}</td>
              <td>{{.Date}}</td>
            </tr>
            {{end}}
          </tbody>
        </table>
        {{end}}

        <div class="doc-footer">
          <span>{{.Icons.Separator}}</span>
          <span>fin. lo lograste.</span>
        </div>

        <!-- Clippy -->
        <div class="clippy-bubble">
          <span class="clippy-label">📎 Clippy</span>
          Parece que estas escribiendo una historia sobre codigo. Tengo mis dudas.
        </div>

      </div>
    </div>

  </body>
  </html>
