name: "formal"
version: "2.0.0"
description: "Professional technical changelog. Clean, precise, no frills."
author: "CommitLore"
tags: ["professional", "technical", "corporate", "clean", "minimal"]
preview_url: ""
homepage: ""

theme:
  mode: "light"
  colors:
    primary: "#0969DA"
    secondary: "#57606A"
    background: "#FFFFFF"
    surface: "#F6F8FA"
    text: "#1A1A2E"
    accent: "#0550AE"
    border: "#D0D7DE"
  typography:
    font_family: "Inter, system-ui, -apple-system, sans-serif"
    font_size_base: "13px"
    font_size_header: "20px"
    font_size_code: "12px"
  logo: ""
  header_image: ""
  card_style: "bordered"
  animations: false
  custom_css: ""
  window_controls:
    default: "#888888"
    close: "#FF5F57"
    minimize: "#FEBC2E"
    maximize: "#28C840"

terminal:
  colors:
    header: "blue"
    feature: "cyan"
    fix: "green"
    breaking: "red"
    footer: "white"
  decorators:
    separator: "────────────────────────────────────────"
    bullet: "•"
    indent: "  "
  density: "normal"

llm_prompt: |
  You are a technical writer creating professional release notes.
  Group related commits by theme or component. Write clear, concise descriptions.
  Identify and prominently mark breaking changes and security fixes.
  Begin with a 3-sentence executive summary describing what this release delivers.
  Normalize inconsistent commit messages into readable, consistent entries.
  Tone: neutral, precise, no marketing language, no exclamation marks.
  Output clean markdown.
  IMPORTANT: Base your output EXCLUSIVELY on the commits provided in the data
  section below. Do not invent features, fixes, or changes that are not present
  in the commit data. Every item must correspond to a real commit. Summarize
  faithfully — do not embellish or expand beyond what is stated.

vocabulary: {}

ui_labels:
  generate_button: "Generate"
  story_button: "Tell the story"

icons:
  feature: "+"
  fix: "✓"
  breaking: "!"
  chore: "·"
  docs: "·"
  test: "·"
  story_peak: "▲"
  bullet: "•"
  separator: "────────────────────────────────────────"

templates:
  header: |
    # Changelog — {{.Version}}
    _{{.Date}}_
  feature: "- **{{.Message}}** (`{{.Hash}}` — {{.Author}})"
  fix: "- fix: {{.Message}} (`{{.Hash}}` — {{.Author}})"
  breaking: "- ⚠ BREAKING: {{.Message}} (`{{.Hash}}` — {{.Author}})"
  footer: |
    ---
    _Generated by CommitLore_
  story_intro: |
    ## Repository Report
    Initialized on {{.FirstCommitDate}} by {{.FirstAuthor}}.
    {{.TotalCommits}} commits by {{.TotalContributors}} contributors.
  story_milestone: "- {{.Name}} (`{{.Hash | short}}`) — {{.Date}}"
  story_peak: "Peak activity: {{.Month}} — {{.Count}} commits"
  story_contributor: "- **{{.Name}}** — first contribution {{.Date}}"
  story_footer: "_Report generated by CommitLore_"

html_template_changelog: |
  <!DOCTYPE html>
  <html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}} — {{.RepoName}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: {{.Theme.Typography.FontSizeBase}}; }
      body {
        font-family: {{.Theme.Typography.FontFamily}};
        background: {{.Theme.Colors.Background}};
        color: {{.Theme.Colors.Text}};
        line-height: 1.6;
        min-height: 100vh;
      }
      a { color: {{.Theme.Colors.Primary}}; text-decoration: none; }
      a:hover { text-decoration: underline; }
      code, pre {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: {{.Theme.Typography.FontSizeCode}};
      }

      /* Header */
      .cl-header {
        height: 60px;
        display: flex;
        align-items: center;
        padding: 0 32px;
        background: {{.Theme.Colors.Background}};
        border-bottom: 1px solid {{.Theme.Colors.Border}};
        gap: 12px;
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .cl-header-logo {
        display: flex;
        align-items: center;
        color: {{.Theme.Colors.Primary}};
        flex-shrink: 0;
        width: 24px;
        height: 24px;
      }
      .cl-header-logo svg { width: 24px; height: 24px; }
      .cl-header-repo {
        font-size: 14px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        letter-spacing: -0.01em;
      }
      .cl-header-sep {
        color: {{.Theme.Colors.Border}};
        font-weight: 300;
        margin: 0 2px;
      }
      .cl-header-title {
        font-size: 13px;
        color: {{.Theme.Colors.Secondary}};
        font-weight: 400;
      }
      .cl-header-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .cl-version-badge {
        display: inline-block;
        padding: 2px 8px;
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 12px;
        font-size: 11px;
        font-weight: 500;
        color: {{.Theme.Colors.Secondary}};
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .cl-header-date {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
      }

      /* Layout */
      .cl-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 40px 32px 80px;
      }

      /* Narrative content */
      .cl-narrative {
        max-width: 720px;
        margin: 0 auto 48px;
        padding: 0;
      }
      .cl-narrative h1, .cl-narrative h2, .cl-narrative h3 {
        color: {{.Theme.Colors.Text}};
        font-size: {{.Theme.Typography.FontSizeH}};
        font-weight: 600;
        margin-bottom: 12px;
        margin-top: 28px;
        letter-spacing: -0.02em;
      }
      .cl-narrative h1 { font-size: 22px; margin-top: 0; }
      .cl-narrative h2 { font-size: 17px; }
      .cl-narrative h3 { font-size: 15px; }
      .cl-narrative p {
        line-height: 1.8;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 14px;
      }
      .cl-narrative ul, .cl-narrative ol {
        padding-left: 20px;
        margin-bottom: 14px;
      }
      .cl-narrative li { line-height: 1.8; margin-bottom: 4px; }
      .cl-narrative strong { font-weight: 600; color: {{.Theme.Colors.Text}}; }
      .cl-narrative em { color: {{.Theme.Colors.Secondary}}; }
      .cl-narrative code {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 4px;
        padding: 1px 5px;
        font-size: {{.Theme.Typography.FontSizeCode}};
        color: {{.Theme.Colors.Primary}};
      }
      .cl-narrative pre {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
        margin-bottom: 16px;
      }
      .cl-narrative pre code {
        background: none;
        border: none;
        padding: 0;
        color: {{.Theme.Colors.Text}};
      }
      .cl-narrative hr {
        border: none;
        border-top: 1px solid {{.Theme.Colors.Border}};
        margin: 24px 0;
      }
      .cl-narrative blockquote {
        border-left: 3px solid {{.Theme.Colors.Primary}};
        padding-left: 16px;
        color: {{.Theme.Colors.Secondary}};
        margin: 0 0 14px;
      }

      /* Section labels */
      .cl-section-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
      }

      /* Stats row */
      .cl-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 48px;
      }
      .cl-stat-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 8px;
        padding: 20px 24px;
      }
      .cl-stat-value {
        font-size: 28px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        letter-spacing: -0.03em;
        line-height: 1;
        margin-bottom: 6px;
      }
      .cl-stat-label {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        font-weight: 500;
      }

      /* Commits table */
      .cl-table-wrap {
        margin-bottom: 48px;
        overflow-x: auto;
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 8px;
      }
      .cl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
      }
      .cl-table thead tr {
        background: {{.Theme.Colors.Surface}};
        border-bottom: 1px solid {{.Theme.Colors.Border}};
      }
      .cl-table th {
        padding: 10px 14px;
        text-align: left;
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: {{.Theme.Colors.Secondary}};
        white-space: nowrap;
      }
      .cl-table td {
        padding: 10px 14px;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
        vertical-align: middle;
      }
      .cl-table tbody tr:last-child td { border-bottom: none; }
      .cl-table tbody tr:nth-child(odd) {
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 5%, transparent);
      }
      .cl-table tbody tr:hover {
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 8%, transparent);
      }
      .cl-type-badge {
        display: inline-block;
        padding: 2px 7px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        white-space: nowrap;
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 12%, {{.Theme.Colors.Surface}});
        color: {{.Theme.Colors.Primary}};
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 25%, transparent);
      }
      .cl-type-badge.type-fix {
        background: color-mix(in srgb, #28a745 12%, {{.Theme.Colors.Surface}});
        color: #28a745;
        border-color: color-mix(in srgb, #28a745 25%, transparent);
      }
      .cl-type-badge.type-breaking {
        background: color-mix(in srgb, #dc3545 12%, {{.Theme.Colors.Surface}});
        color: #dc3545;
        border-color: color-mix(in srgb, #dc3545 25%, transparent);
      }
      .cl-hash {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 11px;
        color: {{.Theme.Colors.Primary}};
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 8%, {{.Theme.Colors.Surface}});
        padding: 2px 6px;
        border-radius: 4px;
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 20%, transparent);
        white-space: nowrap;
      }
      .cl-msg { color: {{.Theme.Colors.Text}}; max-width: 340px; }
      .cl-author { color: {{.Theme.Colors.Secondary}}; white-space: nowrap; }
      .cl-date {
        color: {{.Theme.Colors.Secondary}};
        white-space: nowrap;
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Charts */
      .cl-charts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 48px;
      }
      .cl-chart-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 8px;
        padding: 24px;
      }
      .cl-chart-title {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 20px;
      }
      .cl-chart-wrap {
        position: relative;
        height: 200px;
      }

      /* Tags / Milestones */
      .cl-tags {
        margin-bottom: 48px;
      }
      .cl-tag-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
        font-size: 13px;
      }
      .cl-tag-row:last-child { border-bottom: none; }
      .cl-tag-name {
        font-weight: 600;
        color: {{.Theme.Colors.Primary}};
        min-width: 100px;
      }
      .cl-tag-hash {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 4px;
        padding: 1px 6px;
      }
      .cl-tag-date {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        margin-left: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Contributors */
      .cl-contributors {
        margin-bottom: 48px;
      }
      .cl-contributor-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
      }
      .cl-contributor-row:last-child { border-bottom: none; }
      .cl-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: {{.Theme.Colors.Accent}};
        color: {{.Theme.Colors.Background}};
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: 0.02em;
      }
      .cl-contributor-name {
        font-size: 13px;
        font-weight: 500;
        color: {{.Theme.Colors.Text}};
      }
      .cl-contributor-date {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
        margin-left: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* Footer */
      .cl-footer {
        border-top: 1px solid {{.Theme.Colors.Border}};
        padding-top: 24px;
        margin-top: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
      }
      .cl-footer-sep {
        color: {{.Theme.Colors.Border}};
        font-size: 10px;
        letter-spacing: -0.1em;
        overflow: hidden;
        max-width: 80px;
        white-space: nowrap;
        text-overflow: clip;
      }
    </style>
  </head>
  <body>
    <header class="cl-header">
      {{if .Theme.Logo}}
      <div class="cl-header-logo">{{.Theme.Logo}}</div>
      {{end}}
      <span class="cl-header-repo">{{.RepoName}}</span>
      {{if .Title}}
      <span class="cl-header-sep">/</span>
      <span class="cl-header-title">{{.Title}}</span>
      {{end}}
      <div class="cl-header-right">
        {{if .Version}}<span class="cl-version-badge">{{.Version}}</span>{{end}}
        <span class="cl-header-date">{{.Generated}}</span>
      </div>
    </header>

    <main class="cl-page">

      {{if .Content}}
      <div class="narrative">
        <div class="cl-narrative">{{.Content}}</div>
      </div>
      {{end}}

      {{if .Items}}
      {{/* Changelog mode */}}

      {{/* Stats row */}}
      <div class="cl-stats">
        <div class="cl-stat-card">
          <div class="cl-stat-value">{{len .Items}}</div>
          <div class="cl-stat-label">Total Commits</div>
        </div>
        <div class="cl-stat-card">
          <div class="cl-stat-value" id="feat-count">—</div>
          <div class="cl-stat-label">Features</div>
        </div>
        <div class="cl-stat-card">
          <div class="cl-stat-value" id="fix-count">—</div>
          <div class="cl-stat-label">Fixes</div>
        </div>
      </div>

      {{/* Commits table */}}
      <div class="cl-section-label">Commits</div>
      <div class="cl-table-wrap">
        <table class="cl-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Message</th>
              <th>Hash</th>
              <th>Author</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            {{range .Items}}
            <tr>
              <td>
                <span class="cl-type-badge type-{{lower .Type}}">{{.Icon}} {{.Type}}</span>
              </td>
              <td class="cl-msg">{{.Message}}</td>
              <td><span class="cl-hash">{{.Hash}}</span></td>
              <td class="cl-author">{{.Author}}</td>
              <td class="cl-date">{{.Date}}</td>
            </tr>
            {{end}}
          </tbody>
        </table>
      </div>

      {{/* Donut chart for commit types */}}
      <div class="cl-charts" style="grid-template-columns: 1fr;">
        <div class="cl-chart-card" style="max-width: 400px;">
          <div class="cl-chart-title">Commit Type Distribution</div>
          <div class="cl-chart-wrap">
            <canvas id="typeChart"></canvas>
          </div>
        </div>
      </div>

      <script>
      (function() {
        var items = [
          {{range .Items}}
          { type: "{{lower .Type}}" },
          {{end}}
        ];
        var counts = {};
        items.forEach(function(i) {
          counts[i.type] = (counts[i.type] || 0) + 1;
        });
        var featCount = counts["feat"] || counts["feature"] || 0;
        var fixCount = counts["fix"] || 0;
        var el1 = document.getElementById("feat-count");
        var el2 = document.getElementById("fix-count");
        if (el1) el1.textContent = featCount;
        if (el2) el2.textContent = fixCount;

        var labels = Object.keys(counts);
        var data = labels.map(function(k) { return counts[k]; });
        var primary = "{{.Theme.Colors.Primary}}";
        var accent = "{{.Theme.Colors.Accent}}";
        var secondary = "{{.Theme.Colors.Secondary}}";
        var border = "{{.Theme.Colors.Border}}";
        var bg = "{{.Theme.Colors.Surface}}";
        var palette = [primary, accent, secondary, border, bg];
        while (palette.length < labels.length) {
          palette.push(palette[palette.length - 1]);
        }
        var ctx = document.getElementById("typeChart");
        if (ctx) {
          try {
            new Chart(ctx, {
              type: "doughnut",
              data: {
                labels: labels,
                datasets: [{
                  data: data,
                  backgroundColor: palette.slice(0, labels.length),
                  borderWidth: 0
                }]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                  legend: {
                    position: "right",
                    labels: {
                      color: "{{.Theme.Colors.Text}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 11 },
                      padding: 12
                    }
                  }
                }
              }
            });
          } catch(e) { console.error("Chart error:", e); }
        }
      })();
      </script>

      {{end}}{{/* end .Items */}}

      {{if .Peaks}}
      {{/* Story mode */}}

      {{/* Stats row */}}
      <div class="cl-stats">
        <div class="cl-stat-card">
          <div class="cl-stat-value">{{.TotalCommits}}</div>
          <div class="cl-stat-label">Total Commits</div>
        </div>
        <div class="cl-stat-card">
          <div class="cl-stat-value">{{len .Contributors}}</div>
          <div class="cl-stat-label">Contributors</div>
        </div>
        <div class="cl-stat-card">
          <div class="cl-stat-value">{{len .Tags}}</div>
          <div class="cl-stat-label">Milestones</div>
        </div>
      </div>

      {{/* Activity chart */}}
      <div class="cl-section-label">Activity Peaks</div>
      <div class="cl-charts" style="grid-template-columns: 1fr;">
        <div class="cl-chart-card">
          <div class="cl-chart-title">Commit Activity</div>
          <div class="cl-chart-wrap">
            <canvas id="activityChart"></canvas>
          </div>
        </div>
      </div>

      <script>
      (function() {
        var labels = [{{range .Peaks}}"{{.Month}}",{{end}}];
        var data = [{{range .Peaks}}{{.Count}},{{end}}];
        var ctx = document.getElementById("activityChart");
        if (ctx) {
          try {
            new Chart(ctx, {
              type: "bar",
              data: {
                labels: labels,
                datasets: [{
                  label: "Commits",
                  data: data,
                  backgroundColor: "{{.Theme.Colors.Primary}}",
                  borderRadius: 4,
                  borderSkipped: false
                }]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                  legend: { display: false }
                },
                scales: {
                  x: {
                    grid: { color: "{{.Theme.Colors.Border}}", lineWidth: 1 },
                    ticks: {
                      color: "{{.Theme.Colors.Secondary}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 }
                    }
                  },
                  y: {
                    grid: { color: "{{.Theme.Colors.Border}}", lineWidth: 1 },
                    ticks: {
                      color: "{{.Theme.Colors.Secondary}}",
                      font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 }
                    }
                  }
                }
              }
            });
          } catch(e) { console.error("Chart error:", e); }
        }
      })();
      </script>

      {{if .Tags}}
      <div class="cl-section-label">Milestones</div>
      <div class="cl-tags">
        {{range .Tags}}
        <div class="cl-tag-row">
          <span class="cl-tag-name">{{.Name}}</span>
          <span class="cl-tag-hash">{{.Hash}}</span>
          <span class="cl-tag-date">{{.Date}}</span>
        </div>
        {{end}}
      </div>
      {{end}}

      {{if .Contributors}}
      <div class="cl-section-label">Contributors</div>
      <div class="cl-contributors">
        {{range .Contributors}}
        <div class="cl-contributor-row">
          <div class="cl-avatar">{{initials .Name}}</div>
          <div class="cl-contributor-name">{{.Name}}</div>
          <div class="cl-contributor-date">since {{.Date}}</div>
        </div>
        {{end}}
      </div>
      {{end}}

      {{end}}{{/* end .Peaks */}}

      <footer class="cl-footer">
        <span class="cl-footer-sep">{{.Icons.Separator}}</span>
        <span>Generated by CommitLore</span>
      </footer>

    </main>
  </body>
  </html>

html_template_story: |
  <!DOCTYPE html>
  <html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Repository Report — {{.RepoName}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: {{.Theme.Typography.FontSizeBase}}; }
      body {
        font-family: {{.Theme.Typography.FontFamily}};
        background: {{.Theme.Colors.Background}};
        color: {{.Theme.Colors.Text}};
        line-height: 1.6;
        min-height: 100vh;
      }

      /* ── Report header ── */
      .rp-banner {
        background: {{.Theme.Colors.Surface}};
        border-bottom: 1px solid {{.Theme.Colors.Border}};
        padding: 36px 48px 28px;
      }
      .rp-banner-eyebrow {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 10px;
      }
      .rp-banner-title {
        font-size: 28px;
        font-weight: 700;
        color: {{.Theme.Colors.Text}};
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 6px;
      }
      .rp-banner-repo {
        color: {{.Theme.Colors.Primary}};
      }
      .rp-banner-meta {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-top: 14px;
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
      }
      .rp-banner-meta-sep {
        color: {{.Theme.Colors.Border}};
      }
      .rp-version-badge {
        display: inline-block;
        padding: 2px 9px;
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 10%, {{.Theme.Colors.Surface}});
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 30%, transparent);
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        color: {{.Theme.Colors.Primary}};
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        letter-spacing: 0.02em;
      }

      /* ── Page layout ── */
      .rp-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 40px 48px 80px;
      }

      /* ── Section label ── */
      .rp-section-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: {{.Theme.Colors.Secondary}};
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
      }

      /* ── Executive summary — 4 stat cards ── */
      .rp-exec-summary {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 10px;
        padding: 28px 32px;
        margin-bottom: 44px;
      }
      .rp-exec-summary-heading {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 24px;
        letter-spacing: -0.01em;
      }
      .rp-stat-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
      }
      .rp-stat-cell {
        padding: 4px 20px 4px 0;
        border-right: 1px solid {{.Theme.Colors.Border}};
        margin-right: 20px;
      }
      .rp-stat-cell:last-child {
        border-right: none;
        margin-right: 0;
        padding-right: 0;
      }
      .rp-stat-value {
        font-size: 32px;
        font-weight: 700;
        color: {{.Theme.Colors.Text}};
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 6px;
      }
      .rp-stat-value.primary { color: {{.Theme.Colors.Primary}}; }
      .rp-stat-label {
        font-size: 11px;
        font-weight: 500;
        color: {{.Theme.Colors.Secondary}};
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* ── Narrative prose ── */
      .rp-narrative-wrap {
        max-width: 720px;
        margin: 0 auto 48px;
      }
      .rp-narrative-wrap h1, .rp-narrative-wrap h2, .rp-narrative-wrap h3 {
        color: {{.Theme.Colors.Text}};
        font-weight: 600;
        margin-bottom: 12px;
        margin-top: 28px;
        letter-spacing: -0.02em;
      }
      .rp-narrative-wrap h1 { font-size: 22px; margin-top: 0; }
      .rp-narrative-wrap h2 { font-size: 17px; }
      .rp-narrative-wrap h3 { font-size: 15px; }
      .rp-narrative-wrap p {
        line-height: 1.8;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 14px;
      }
      .rp-narrative-wrap ul, .rp-narrative-wrap ol {
        padding-left: 20px;
        margin-bottom: 14px;
      }
      .rp-narrative-wrap li { line-height: 1.8; margin-bottom: 4px; }
      .rp-narrative-wrap strong { font-weight: 600; }
      .rp-narrative-wrap em { color: {{.Theme.Colors.Secondary}}; }
      .rp-narrative-wrap code {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 4px;
        padding: 1px 5px;
        font-size: {{.Theme.Typography.FontSizeCode}};
        color: {{.Theme.Colors.Primary}};
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .rp-narrative-wrap pre {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
        margin-bottom: 16px;
      }
      .rp-narrative-wrap pre code { background: none; border: none; padding: 0; color: {{.Theme.Colors.Text}}; }
      .rp-narrative-wrap hr { border: none; border-top: 1px solid {{.Theme.Colors.Border}}; margin: 24px 0; }
      .rp-narrative-wrap blockquote {
        border-left: 3px solid {{.Theme.Colors.Primary}};
        padding-left: 16px;
        color: {{.Theme.Colors.Secondary}};
        margin: 0 0 14px;
      }

      /* ── Charts row ── */
      .rp-charts-row {
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: 24px;
        margin-bottom: 48px;
      }
      .rp-chart-card {
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 8px;
        padding: 24px;
      }
      .rp-chart-title {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 20px;
        letter-spacing: -0.01em;
      }
      .rp-chart-subtitle {
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        font-weight: 400;
        margin-left: 6px;
      }
      .rp-chart-wrap {
        position: relative;
        height: 220px;
      }

      /* ── Vertical timeline ── */
      .rp-timeline {
        position: relative;
        margin-bottom: 48px;
        padding-left: 28px;
      }
      .rp-timeline::before {
        content: "";
        position: absolute;
        left: 7px;
        top: 6px;
        bottom: 6px;
        width: 2px;
        background: {{.Theme.Colors.Border}};
      }
      .rp-timeline-item {
        position: relative;
        margin-bottom: 20px;
        padding-bottom: 4px;
      }
      .rp-timeline-item:last-child { margin-bottom: 0; }
      .rp-timeline-dot {
        position: absolute;
        left: -24px;
        top: 4px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: {{.Theme.Colors.Primary}};
        border: 2px solid {{.Theme.Colors.Background}};
        box-shadow: 0 0 0 2px {{.Theme.Colors.Primary}};
      }
      .rp-timeline-month {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        margin-bottom: 2px;
        letter-spacing: -0.01em;
      }
      .rp-timeline-note {
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
      }
      .rp-timeline-count {
        display: inline-block;
        padding: 1px 7px;
        background: color-mix(in srgb, {{.Theme.Colors.Primary}} 12%, {{.Theme.Colors.Surface}});
        border: 1px solid color-mix(in srgb, {{.Theme.Colors.Primary}} 25%, transparent);
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
        color: {{.Theme.Colors.Primary}};
        margin-left: 8px;
        vertical-align: middle;
      }

      /* ── Tags / Milestones ── */
      .rp-tags {
        margin-bottom: 48px;
      }
      .rp-tag-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
        font-size: 13px;
      }
      .rp-tag-row:last-child { border-bottom: none; }
      .rp-tag-indicator {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: {{.Theme.Colors.Primary}};
        flex-shrink: 0;
      }
      .rp-tag-name {
        font-weight: 600;
        color: {{.Theme.Colors.Primary}};
        min-width: 100px;
      }
      .rp-tag-hash {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        background: {{.Theme.Colors.Surface}};
        border: 1px solid {{.Theme.Colors.Border}};
        border-radius: 4px;
        padding: 1px 6px;
      }
      .rp-tag-date {
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        margin-left: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }

      /* ── Contributors list ── */
      .rp-contributors {
        margin-bottom: 48px;
      }
      .rp-contrib-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid {{.Theme.Colors.Border}};
      }
      .rp-contrib-row:last-child { border-bottom: none; }
      .rp-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: {{.Theme.Colors.Accent}};
        color: {{.Theme.Colors.Background}};
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: 0.02em;
      }
      .rp-contrib-info { flex: 1; min-width: 0; }
      .rp-contrib-name {
        font-size: 13px;
        font-weight: 600;
        color: {{.Theme.Colors.Text}};
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .rp-contrib-email {
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .rp-contrib-meta {
        text-align: right;
        flex-shrink: 0;
      }
      .rp-contrib-count {
        font-size: 15px;
        font-weight: 700;
        color: {{.Theme.Colors.Text}};
        letter-spacing: -0.02em;
        line-height: 1;
      }
      .rp-contrib-count-label {
        font-size: 10px;
        color: {{.Theme.Colors.Secondary}};
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .rp-contrib-date {
        font-size: 11px;
        color: {{.Theme.Colors.Secondary}};
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        margin-top: 2px;
      }

      /* ── Footer ── */
      .rp-footer {
        border-top: 1px solid {{.Theme.Colors.Border}};
        padding-top: 24px;
        margin-top: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: {{.Theme.Colors.Secondary}};
      }
      .rp-footer-sep {
        color: {{.Theme.Colors.Border}};
        font-size: 10px;
        letter-spacing: -0.1em;
        overflow: hidden;
        max-width: 80px;
        white-space: nowrap;
        text-overflow: clip;
      }
    </style>
  </head>
  <body>

    <!-- Report banner -->
    <div class="rp-banner">
      <div class="rp-banner-eyebrow">Repository Report</div>
      <div class="rp-banner-title">
        <span class="rp-banner-repo">{{.RepoName}}</span>
      </div>
      <div class="rp-banner-meta">
        {{if .FirstDate}}<span>{{.FirstDate}} &rarr; {{.Generated}}</span><span class="rp-banner-meta-sep">&middot;</span>{{end}}
        <span>{{.Generated}}</span>
        {{if .Version}}<span class="rp-banner-meta-sep">&middot;</span><span class="rp-version-badge">{{.Version}}</span>{{end}}
      </div>
    </div>

    <main class="rp-page">

      <!-- Executive summary: 4 stat cards -->
      <div class="rp-exec-summary">
        <div class="rp-exec-summary-heading">Executive Summary</div>
        <div class="rp-stat-row">
          <div class="rp-stat-cell">
            <div class="rp-stat-value primary">{{.TotalCommits}}</div>
            <div class="rp-stat-label">Total Commits</div>
          </div>
          <div class="rp-stat-cell">
            <div class="rp-stat-value">{{len .Contributors}}</div>
            <div class="rp-stat-label">Contributors</div>
          </div>
          <div class="rp-stat-cell">
            {{if .FirstDate}}
            <div class="rp-stat-value" style="font-size:14px;letter-spacing:-0.01em;padding-top:9px;">{{.FirstDate}}</div>
            {{else}}
            <div class="rp-stat-value">—</div>
            {{end}}
            <div class="rp-stat-label">First Commit</div>
          </div>
          <div class="rp-stat-cell">
            {{if .Peaks}}
            <div class="rp-stat-value" style="font-size:16px;letter-spacing:-0.01em;padding-top:8px;">{{(index .Peaks 0).Month}}</div>
            {{else}}
            <div class="rp-stat-value">—</div>
            {{end}}
            <div class="rp-stat-label">Most Active Month</div>
          </div>
        </div>
      </div>

      <!-- Narrative prose -->
      {{if .Content}}
      <div class="rp-narrative-wrap">
        {{.Content}}
      </div>
      {{end}}

      <!-- Activity line chart + contributor bar chart side by side -->
      {{if .Peaks}}
      <div class="rp-section-label">Activity Overview</div>
      <div class="rp-charts-row">
        <div class="rp-chart-card">
          <div class="rp-chart-title">
            Commit Arc
            <span class="rp-chart-subtitle">commits per month</span>
          </div>
          <div class="rp-chart-wrap">
            <canvas id="arcChart"></canvas>
          </div>
        </div>
        {{if .Contributors}}
        <div class="rp-chart-card">
          <div class="rp-chart-title">
            Contributor Ranking
            <span class="rp-chart-subtitle">by commit count</span>
          </div>
          <div class="rp-chart-wrap">
            <canvas id="contribChart"></canvas>
          </div>
        </div>
        {{end}}
      </div>

      <script>
      (function() {
        if (typeof Chart === "undefined") { console.error("Chart.js not loaded"); return; }

        // --- Line chart: commit arc ---
        var arcLabels = [{{range .Peaks}}"{{.Month}}",{{end}}];
        var arcData   = [{{range .Peaks}}{{.Count}},{{end}}];
        var ctxArc = document.getElementById("arcChart");
        if (ctxArc) {
          try {
            new Chart(ctxArc, {
              type: "line",
              data: {
                labels: arcLabels,
                datasets: [{
                  label: "Commits",
                  data: arcData,
                  borderColor: "{{.Theme.Colors.Primary}}",
                  backgroundColor: "color-mix(in srgb, {{.Theme.Colors.Primary}} 12%, transparent)",
                  borderWidth: 2,
                  pointBackgroundColor: "{{.Theme.Colors.Primary}}",
                  pointRadius: 4,
                  pointHoverRadius: 6,
                  tension: 0.35,
                  fill: true
                }]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                  x: {
                    grid: { color: "{{.Theme.Colors.Border}}", lineWidth: 1 },
                    ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 }, maxRotation: 45 }
                  },
                  y: {
                    beginAtZero: true,
                    grid: { color: "{{.Theme.Colors.Border}}", lineWidth: 1 },
                    ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 } }
                  }
                }
              }
            });
          } catch(e) { console.error("arcChart error:", e); }
        }

        // --- Horizontal bar chart: contributor ranking ---
        var contribNames  = [{{range .Contributors}}"{{.Name}}",{{end}}];
        var contribCounts = [{{range .Contributors}}{{.Count}},{{end}}];
        var ctxContrib = document.getElementById("contribChart");
        if (ctxContrib && contribNames.length > 0) {
          try {
            new Chart(ctxContrib, {
              type: "bar",
              data: {
                labels: contribNames,
                datasets: [{
                  label: "Commits",
                  data: contribCounts,
                  backgroundColor: "{{.Theme.Colors.Accent}}",
                  borderRadius: 3,
                  borderSkipped: false
                }]
              },
              options: {
                indexAxis: "y",
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                  x: {
                    beginAtZero: true,
                    grid: { color: "{{.Theme.Colors.Border}}", lineWidth: 1 },
                    ticks: { color: "{{.Theme.Colors.Secondary}}", font: { family: "{{.Theme.Typography.FontFamily}}", size: 10 } }
                  },
                  y: {
                    grid: { display: false },
                    ticks: { color: "{{.Theme.Colors.Text}}", font: { family: "{{.Theme.Typography.FontFamily}}", size: 11 } }
                  }
                }
              }
            });
          } catch(e) { console.error("contribChart error:", e); }
        }
      })();
      </script>

      <!-- Vertical dot timeline for peak months -->
      <div class="rp-section-label">Monthly Timeline</div>
      <div class="rp-timeline">
        {{range .Peaks}}
        <div class="rp-timeline-item">
          <div class="rp-timeline-dot"></div>
          <div class="rp-timeline-month">
            {{.Month}}
            <span class="rp-timeline-count">{{.Count}} commits</span>
          </div>
          <div class="rp-timeline-note">{{.Count}} commit{{if gt .Count 1}}s{{end}} recorded this month</div>
        </div>
        {{end}}
      </div>

      {{end}}{{/* end .Peaks */}}

      <!-- Tags / Milestones -->
      {{if .Tags}}
      <div class="rp-section-label">Release Milestones</div>
      <div class="rp-tags">
        {{range .Tags}}
        <div class="rp-tag-row">
          <div class="rp-tag-indicator"></div>
          <span class="rp-tag-name">{{.Name}}</span>
          <span class="rp-tag-hash">{{.Hash}}</span>
          <span class="rp-tag-date">{{.Date}}</span>
        </div>
        {{end}}
      </div>
      {{end}}

      <!-- Contributors list with initials circles -->
      {{if .Contributors}}
      <div class="rp-section-label">Contributors</div>
      <div class="rp-contributors">
        {{range .Contributors}}
        <div class="rp-contrib-row">
          <div class="rp-avatar">{{initials .Name}}</div>
          <div class="rp-contrib-info">
            <div class="rp-contrib-name">{{.Name}}</div>
            {{if .Email}}<div class="rp-contrib-email">{{.Email}}</div>{{end}}
            {{if .Date}}<div class="rp-contrib-date">since {{.Date}}</div>{{end}}
          </div>
          {{if .Count}}
          <div class="rp-contrib-meta">
            <div class="rp-contrib-count">{{.Count}}</div>
            <div class="rp-contrib-count-label">commits</div>
          </div>
          {{end}}
        </div>
        {{end}}
      </div>
      {{end}}

      {{if .Items}}
      {{/* guard: .Items is not populated for story, but kept for safety */}}
      {{end}}

      <footer class="rp-footer">
        <span class="rp-footer-sep">{{.Icons.Separator}}</span>
        <span>Generated by CommitLore</span>
      </footer>

    </main>
  </body>
  </html>

