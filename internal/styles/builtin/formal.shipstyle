name: formal
version: 1.0.0
description: "Technical and professional changelog — clean, precise, no frills"
author: "commitlore"
tags: ["professional", "technical", "corporate", "clean", "minimal"]
preview_url: ""
homepage: ""
llm_prompt: |
  You are a senior technical writer producing a changelog for a professional
  software project. Write in a precise, neutral, corporate tone. Use past
  tense and active voice throughout. Every entry must state exactly what
  changed and why, with zero embellishment. No emojis, no humor, no
  metaphors. Structure: group by type (Added, Fixed, Breaking), then list
  entries as bullet points. End with a brief summary of the release scope.
  If there are breaking changes, lead with them and explain migration steps.
  Keep sentences under 20 words. Prefer "Added X" over "We added X".
templates:
  header: "# Changelog"
  feature: "- Added: {{.Message}} ({{.Hash | short}}, {{.Author}})"
  fix: "- Fixed: {{.Message}} ({{.Hash | short}}, {{.Author}})"
  breaking: "- BREAKING: {{.Message}} ({{.Hash | short}}, {{.Author}})"
  footer: ""
  story_intro: "# Repository Story\n\nThis repository was initialized on {{.FirstCommitDate}} by {{.FirstAuthor}}.\nTotal commits analyzed: {{.TotalCommits}}. Distinct contributors: {{.TotalContributors}}."
  story_milestone: "- Release {{.Name}} published on {{.Date}}"
  story_peak: "- {{.Month}}: {{.Count}} commits recorded"
  story_contributor: "- {{.Name}}, first contribution on {{.Date}}"
  story_footer: ""
vocabulary: {}
theme:
  mode: "light"
  colors:
    primary: "#2563EB"
    secondary: "#1E40AF"
    background: "#F8FAFC"
    surface: "#FFFFFF"
    text: "#1E293B"
    accent: "#3B82F6"
    border: "#E2E8F0"
  typography:
    font_family: "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
    font_size_base: "14px"
    font_size_header: "24px"
    font_size_code: "13px"
  card_style: "minimal"
  animations: false
  custom_css: |
    body { line-height: 1.6; }
    h1 { font-weight: 700; letter-spacing: -0.02em; }
    h2 { font-weight: 600; }
    li { font-size: 0.95em; }
    .hash { background: #F1F5F9; padding: 0.1em 0.3em; border-radius: 3px; }
terminal:
  colors:
    header: "white"
    feature: "cyan"
    fix: "green"
    breaking: "red"
    footer: "white"
  decorators:
    separator: "────────────────────────────────────────"
    bullet: "-"
    indent: "  "
  density: "normal"
