name: formal
version: 1.0.0
description: "Technical and professional changelog style"
author: "commitlore"
llm_prompt: |
  Write the changelog in a technical, professional tone.
  Be concise and precise. Use past tense. Group changes by type.
  Each entry should state what changed and why, without embellishment.
  Use active voice: "Added X", "Fixed Y", "Removed Z".
templates:
  header: "# Changelog"
  feature: "- Added: {{.Message}} ({{.Hash | short}}, {{.Author}})"
  fix: "- Fixed: {{.Message}} ({{.Hash | short}}, {{.Author}})"
  breaking: "- ⚠ BREAKING: {{.Message}} ({{.Hash | short}}, {{.Author}})"
  footer: ""
  story_intro: "# Repository Story\n\nThis repository was created on {{.FirstCommitDate}} by {{.FirstAuthor}}.\nTotal commits: {{.TotalCommits}}. Contributors: {{.TotalContributors}}."
  story_milestone: "- Tag {{.Name}} released on {{.Date}}"
  story_peak: "- {{.Month}}: {{.Count}} commits"
  story_contributor: "- {{.Name}}, first commit on {{.Date}}"
  story_footer: ""
